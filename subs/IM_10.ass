Dialogue: 0,0:00:02.41,0:00:04.20,Credits,,100,0,80,,{\fad(600,200)\an1\fs25}Tradução:Juan Tlgd\NRevisão: RAFAEL
Dialogue: 0,0:00:37.58,0:00:38.87,Main,,0,0,0,,Ei.
Dialogue: 0,0:00:39.25,0:00:41.54,Main,,0,0,0,,Vão jogar quem na água?
Dialogue: 0,0:00:42.58,0:00:45.17,Main,,0,0,0,,Vocês desconhecem seus próprios limites.
Dialogue: 0,0:00:49.05,0:00:51.22,Main,,0,0,0,,Não tenham medo!\NJoguem-nos ao mar!
Dialogue: 0,0:01:05.11,0:01:06.23,Main,,0,0,0,,Aquele é...
Dialogue: 0,0:01:09.74,0:01:10.86,Main,,0,0,0,,Jinbe!
Dialogue: 0,0:01:11.20,0:01:13.87,Main,,0,0,0,,Karatê dos Homens-Peixe!
Dialogue: 0,0:01:16.12,0:01:19.12,Main,,0,0,0,,Yarinami!
Dialogue: 0,0:01:16.12,0:01:19.12,Note,,0,0,0,,Lança de Ondas!
Dialogue: 0,0:01:36.81,0:01:37.93,Main,,0,0,0,,Ei, cara...
Dialogue: 0,0:01:41.23,0:01:43.52,Main,,0,0,0,,Eu não devia ter feito isso.
Dialogue: 0,0:01:43.52,0:01:47.23,Main,,0,0,0,,Nós íamos usar aquele navio!
Dialogue: 0,0:02:15.06,0:02:17.47,Main,,0,0,0,,Gomu Gomu no...
Dialogue: 0,0:02:17.47,0:02:20.85,Main,,0,0,0,,Não, não! Fuja, Chapéu de Palha!
Dialogue: 0,0:02:21.65,0:02:26.36,Main,,0,0,0,,...Chanpion Sutampu!
Dialogue: 0,0:02:26.94,0:02:30.20,Main,,0,0,0,,Você passou dos limites!\NA cera não vai mais funcionar!
Dialogue: 0,0:02:35.62,0:02:37.33,Main,,0,0,0,,Derreter...
Dialogue: 0,0:02:37.33,0:02:38.62,Main,,0,0,0,,Cera!
Dialogue: 0,0:02:44.38,0:02:45.59,Main,,0,0,0,,Essa foi por pouco!
Dialogue: 0,0:02:45.80,0:02:51.14,Main,,0,0,0,,Benomu Dēmon!
Dialogue: 0,0:02:45.80,0:02:51.14,Note,,0,0,0,,Demônio... Venenoso!
Dialogue: 0,0:03:13.20,0:03:14.49,Main,,0,0,0,,Precisamos correr!
Dialogue: 0,0:03:14.49,0:03:16.25,Main,,0,0,0,,Vamos logo!
Dialogue: 0,0:03:24.09,0:03:26.21,Main,,0,0,0,,Jigoku no Shinpan!
Dialogue: 0,0:03:24.09,0:03:26.21,Note,,0,0,0,,Julgamento Infernal!
Dialogue: 0,0:03:30.72,0:03:32.51,Main,,0,0,0,,Droga!
Dialogue: 0,0:03:32.81,0:03:35.98,Main,,0,0,0,,Pessoal, me ajudem!\NEu quero ir com vocês!
Dialogue: 0,0:03:36.60,0:03:36.93,Main,,0,0,0,,Ei!
Dialogue: 0,0:03:36.93,0:03:39.10,Main,,0,0,0,,Idiota! Não encoste em mim!
Dialogue: 0,0:03:40.23,0:03:42.32,Main,,0,0,0,,O veneno está se espalhando!
Dialogue: 0,0:03:48.74,0:03:50.91,Main,,0,0,0,,Seja pela cera ou pela rocha,
Dialogue: 0,0:03:50.91,0:03:55.04,Main,,0,0,0,,o veneno está se espalhando\Ncomo uma infecção!
Dialogue: 0,0:03:55.04,0:03:59.50,Main,,0,0,0,,Droga! É por isso que a Armadura\Nde Cera não funcionou!
Dialogue: 0,0:04:04.26,0:04:06.42,Captions,,0,0,0,,Impel Down - Acima do Nível do Mar\NPortão Principal
Dialogue: 0,0:04:08.84,0:04:12.68,Main,,0,0,0,,Tomara que o Palhinha e os outros estejam bem!
Dialogue: 0,0:04:13.81,0:04:15.56,Main,,0,0,0,,E os navios?
Dialogue: 0,0:04:15.56,0:04:17.31,Main,,0,0,0,,Estou ouvindo disparos...
Dialogue: 0,0:04:17.31,0:04:21.11,Main,,0,0,0,,Mas não dá pra ver\Nnada com essa neblina!
Dialogue: 0,0:04:21.11,0:04:26.53,Main,,0,0,0,,Eu sei que eles são capazes\Nde roubar um navio, mas...
Dialogue: 0,0:04:27.91,0:04:30.07,Main,,0,0,0,,Mas é muito longe!
Dialogue: 0,0:04:30.07,0:04:34.12,Main,,0,0,0,,Eles precisam roubá-lo\Ne ainda voltar até aqui!
Dialogue: 0,0:04:34.12,0:04:38.21,Main,,0,0,0,,Então eles não conseguirão chegar\Naqui antes do Magellan?!
Dialogue: 0,0:04:39.46,0:04:42.50,Main,,0,0,0,,Eu sei que o Chapéu de Palha é forte...
Dialogue: 0,0:04:42.50,0:04:46.76,Main,,0,0,0,,Mas acho que não conseguirá\Nimpedir o Magellan por tanto tempo!
Dialogue: 0,0:04:48.22,0:04:50.01,Main,,0,0,0,,Palhinha!
Dialogue: 0,0:04:50.30,0:04:55.06,Main,,0,0,0,,Droga! Anda logo com isso, Jinbe!
Dialogue: 0,0:05:05.57,0:05:08.91,Main,,0,0,0,,Joguem-nos para fora!\NEles não podem pegar o navio!
Dialogue: 0,0:05:16.92,0:05:20.80,Main,,0,0,0,,O que aconteceu com o corpo dele?!\NParece que é uma lâmina!
Dialogue: 0,0:05:21.50,0:05:22.96,Main,,0,0,0,,Eu comi a Fruta da Lâmina.
Dialogue: 0,0:05:26.84,0:05:30.89,Main,,0,0,0,,Eu me lembro dele!\NÉ um assassino do West Blue...
Dialogue: 0,0:05:30.89,0:05:31.64,Main,,0,0,0,,Daz!
Dialogue: 0,0:05:34.27,0:05:35.81,Main,,0,0,0,,Sāburusu!
Dialogue: 0,0:05:42.32,0:05:45.24,Main,,0,0,0,,É só questão de tempo\Naté que roubem o navio!
Dialogue: 0,0:05:45.24,0:05:47.45,Main,,0,0,0,,Será uma desonra para a Marinha!
Dialogue: 0,0:05:47.45,0:05:49.03,Main,,0,0,0,,Afundem-no imediatamente!
Dialogue: 0,0:05:49.45,0:05:51.83,Main,,0,0,0,,Preparem-se para disparar!
Dialogue: 0,0:05:55.79,0:05:57.21,Main,,0,0,0,,Lá vem a coluna d'água de novo!
Dialogue: 0,0:06:03.42,0:06:05.76,Main,,0,0,0,,Droga! A pólvora molhou!
Dialogue: 0,0:06:05.76,0:06:06.64,Main,,0,0,0,,Deve ser Jinbe!
Dialogue: 0,0:06:09.01,0:06:11.43,Main,,0,0,0,,Atirem com as outras baterias!
Dialogue: 0,0:06:13.43,0:06:16.90,Main,,0,0,0,,Rápido! Ele está bem atrás de nós!
Dialogue: 0,0:06:18.31,0:06:21.44,Main,,0,0,0,,Jinbe!
Dialogue: 0,0:06:34.50,0:06:38.71,Main,,0,0,0,,Ei! Estão todos aqui?!
Dialogue: 0,0:06:39.71,0:06:41.05,Main,,0,0,0,,Ouvi o Palhinha!
Dialogue: 0,0:06:43.42,0:06:44.97,Main,,0,0,0,,Fujam!
Dialogue: 0,0:06:52.02,0:06:55.02,Main,,0,0,0,,Eles estão sendo perseguidos\Npor algo horrível!
Dialogue: 0,0:06:55.02,0:06:57.65,Main,,0,0,0,,É Magellan! Não temos como fugir dele!
Dialogue: 0,0:07:00.11,0:07:01.94,Main,,0,0,0,,Vocês já conseguiram um navio?!
Dialogue: 0,0:07:01.94,0:07:05.24,Main,,0,0,0,,Palhinha! Infelizmente,\Nainda não temos nada!
Dialogue: 0,0:07:05.66,0:07:07.24,Main,,0,0,0,,O quê?!
Dialogue: 0,0:07:11.83,0:07:14.92,Main,,0,0,0,,Desu Winku!
Dialogue: 0,0:07:29.60,0:07:31.02,Main,,0,0,0,,Ivan?!
Dialogue: 0,0:07:33.39,0:07:35.48,Main,,0,0,0,,Que baita susto!
Dialogue: 0,0:07:35.48,0:07:39.65,Main,,0,0,0,,P-Parece que cheguei\Nbem a tempo! Ugh!
Dialogue: 0,0:07:39.65,0:07:42.32,Main,,0,0,0,,Ele desmaiou depois\Nde bater a cabeça!
Dialogue: 0,0:07:44.45,0:07:48.54,Main,,0,0,0,,Ivan! Inazuma!\NVocês estão vivos!
Dialogue: 0,0:07:48.54,0:07:49.95,Main,,0,0,0,,Que bom!
Dialogue: 0,0:07:49.95,0:07:52.12,Main,,0,0,0,,Grande Ivan!
Dialogue: 0,0:07:52.92,0:07:54.46,Main,,0,0,0,,Aqueles dois!
Dialogue: 0,0:07:55.88,0:07:57.96,Main,,0,0,0,,Chapéu de Palha! É do Jinbe!
Dialogue: 0,0:08:00.63,0:08:02.05,Main,,0,0,0,,O Caracol Comunicador Bebê?!
Dialogue: 0,0:08:03.84,0:08:06.01,Main,,0,0,0,,Bom trabalho, pessoal!
Dialogue: 0,0:08:06.01,0:08:08.06,Main,,0,0,0,,Por que você veio?
Dialogue: 0,0:08:08.89,0:08:10.98,Main,,0,0,0,,Luffy! Conseguiram sair?
Dialogue: 0,0:08:10.98,0:08:13.65,Main,,0,0,0,,Sim, mas ele continua atrás da gente!
Dialogue: 0,0:08:13.65,0:08:16.57,Main,,0,0,0,,E estamos ficando sem\Nter para onde correr!
Dialogue: 0,0:08:16.57,0:08:19.61,Main,,0,0,0,,Sinto muito! Já conseguimos um navio...
Dialogue: 0,0:08:19.61,0:08:22.15,Main,,0,0,0,,Mas demoraremos a chegar aí!
Dialogue: 0,0:08:22.15,0:08:25.99,Main,,0,0,0,,Não parem! Pulem na água!
Dialogue: 0,0:08:25.99,0:08:28.41,Main,,0,0,0,,E jogue todos os outros na água!
Dialogue: 0,0:08:28.41,0:08:32.08,Main,,0,0,0,,Como assim, Jinbe?!\NEstamos no Calm Belt!
Dialogue: 0,0:08:32.08,0:08:35.46,Main,,0,0,0,,Deixem o resto comigo!
Dialogue: 0,0:08:37.67,0:08:39.59,Main,,0,0,0,,Vamos fazer o que ele diz!
Dialogue: 0,0:08:39.59,0:08:41.43,Main,,0,0,0,,Três, me ajuda de novo!
Dialogue: 0,0:08:41.43,0:08:45.60,Main,,0,0,0,,Tá doido?! Se cairmos na água,\Nvamos morrer!
Dialogue: 0,0:08:45.60,0:08:47.43,Main,,0,0,0,,Ele é um pau-mandado do Governo!
Dialogue: 0,0:08:47.43,0:08:50.52,Main,,0,0,0,,Não podemos confiar naquele Homem-Peixe!
Dialogue: 0,0:08:50.52,0:08:54.11,Main,,0,0,0,,Ele é amigo do Ace!\NEu confio nele!
Dialogue: 0,0:08:59.15,0:09:01.86,Main,,0,0,0,,Na água?! Mergulhem se quiserem!
Dialogue: 0,0:09:01.86,0:09:04.74,Main,,0,0,0,,Há ninhos de Reis dos Mares\Npor toda parte!
Dialogue: 0,0:09:05.83,0:09:09.37,Main,,0,0,0,,Cuidado! Você não pode encostar\Nnuma gota sequer do veneno!
Dialogue: 0,0:09:10.50,0:09:13.29,Main,,0,0,0,,- Não vamos vencer!\N- Vamos morrer!
Dialogue: 0,0:09:15.42,0:09:17.88,Main,,0,0,0,,Jigoku no Shinpan!
Dialogue: 0,0:09:20.34,0:09:22.30,Main,,0,0,0,,Gia Sādo!
Dialogue: 0,0:09:23.30,0:09:29.14,Main,,0,0,0,,Aqui vai uma surpresa em\Ntamanho-família! Kyandoru Wōru!
Dialogue: 0,0:09:30.52,0:09:32.27,Main,,0,0,0,,Inútil!
Dialogue: 0,0:09:36.32,0:09:38.65,Main,,0,0,0,,Gomu Gomu no...
Dialogue: 0,0:09:39.95,0:09:43.78,Main,,0,0,0,,...Giganto Sutampu!
Dialogue: 0,0:10:02.80,0:10:05.64,Main,,0,0,0,,Nossa! Ele o empurrou para trás!
Dialogue: 0,0:10:18.99,0:10:21.20,Main,,0,0,0,,O veneno continua se espalhando!
Dialogue: 0,0:10:21.20,0:10:23.20,Main,,0,0,0,,Será que devemos\Nmesmo mergulhar?!
Dialogue: 0,0:10:26.54,0:10:29.21,Main,,0,0,0,,Lá vem!
Dialogue: 0,0:10:29.21,0:10:31.96,Main,,0,0,0,,Ivanzinho! Ivanzinho, acorde!
Dialogue: 0,0:10:31.96,0:10:36.01,Main,,0,0,0,,Estamos enrascados!\NIvanzinho, acorda!
Dialogue: 0,0:10:36.01,0:10:38.59,Main,,0,0,0,,Ei, você precisa acordar agora!
Dialogue: 0,0:10:38.59,0:10:39.84,Main,,0,0,0,,O que você quer?
Dialogue: 0,0:10:39.84,0:10:41.47,Main,,0,0,0,,Precisamos ir embora!
Dialogue: 0,0:10:41.47,0:10:43.85,Main,,0,0,0,,Você é filho do Chapéu de Palha?
Dialogue: 0,0:10:43.85,0:10:45.02,Main,,0,0,0,,Consegue piscar?!
Dialogue: 0,0:10:45.02,0:10:45.77,Main,,0,0,0,,Certo!
Dialogue: 0,0:10:46.31,0:10:49.06,Main,,0,0,0,,Ei, não pode ser! Desse jeito, nós vamos...
Dialogue: 0,0:10:49.06,0:10:50.40,Main,,0,0,0,,Lá vamos nós!
Dialogue: 0,0:10:50.40,0:10:52.44,Main,,0,0,0,,Espere, Grande Ivan!
Dialogue: 0,0:10:53.44,0:10:54.98,Main,,0,0,0,,Isso é inimaginável!
Dialogue: 0,0:10:54.98,0:10:59.16,Main,,0,0,0,,Se entrarem no mar sem um navio,\Nnão vão sobreviver por muito tempo!
Dialogue: 0,0:11:00.07,0:11:02.33,Main,,0,0,0,,Pessoal! Se segurem na cara dele!
Dialogue: 0,0:11:02.33,0:11:03.58,Main,,0,0,0,,Na cara?!
Dialogue: 0,0:11:03.58,0:11:05.75,Main,,0,0,0,,Mas eu não vou permitir que fujam!
Dialogue: 0,0:11:08.12,0:11:09.54,Main,,0,0,0,,Heru...
Dialogue: 0,0:11:11.34,0:11:13.00,Main,,0,0,0,,...Winku!
Dialogue: 0,0:11:16.30,0:11:18.09,Main,,0,0,0,,Não permitirei!
Dialogue: 0,0:11:32.57,0:11:36.24,Main,,0,0,0,,Vamos cair!
Dialogue: 0,0:11:38.45,0:11:40.07,Main,,0,0,0,,Tem algo sob o navio!
Dialogue: 0,0:11:40.53,0:11:42.49,Main,,0,0,0,,O que são?!
Dialogue: 0,0:11:47.04,0:11:48.17,Main,,0,0,0,,O que é isto?!
Dialogue: 0,0:11:48.83,0:11:51.17,Main,,0,0,0,,Nós aterrissamos em alguma coisa!
Dialogue: 0,0:11:51.17,0:11:53.71,Main,,0,0,0,,Ei, vejam!
Dialogue: 0,0:11:53.71,0:11:55.42,Main,,0,0,0,,O quê?
Dialogue: 0,0:11:55.42,0:11:57.76,Main,,0,0,0,,Vocês chegaram a tempo!
Dialogue: 0,0:11:57.76,0:12:01.39,Main,,0,0,0,,Sinto muito por pedir-lhes que\Nviessem a uma região tão perigosa!
Dialogue: 0,0:12:24.96,0:12:27.17,Main,,0,0,0,,É um cardume de tubarões-baleia!
Dialogue: 0,0:12:27.17,0:12:30.00,Main,,0,0,0,,Jinbe deve ter convocado!
Dialogue: 0,0:12:33.13,0:12:34.97,Main,,0,0,0,,Demais!
Dialogue: 0,0:12:55.40,0:12:57.53,Main,,0,0,0,,Esse cara é muito maneiro!
Dialogue: 0,0:13:12.42,0:13:14.17,Main,,0,0,0,,Beleza!
Dialogue: 0,0:13:42.96,0:13:47.04,Main,,0,0,0,,Viva! Chegamos ao navio da Marinha!
Dialogue: 0,0:13:47.71,0:13:49.71,Main,,0,0,0,,Escapamos!
Dialogue: 0,0:13:49.71,0:13:53.84,Main,,0,0,0,,Não acredito que\Nfugimos de Impel Down!
Dialogue: 0,0:13:54.22,0:13:58.05,Main,,0,0,0,,Ainda é cedo para comemorar!\NTemos que botar esse navio pra funcionar!
Dialogue: 0,0:14:03.85,0:14:05.48,Main,,0,0,0,,Sim!
Dialogue: 0,0:14:05.48,0:14:08.48,Main,,0,0,0,,Valeu, tubarões-baleia!
Dialogue: 0,0:14:08.48,0:14:10.15,Main,,0,0,0,,Muito obrigado!
Dialogue: 0,0:14:13.20,0:14:15.07,Main,,0,0,0,,Voltem em segurança!
Dialogue: 0,0:14:18.91,0:14:21.20,Main,,0,0,0,,Começarei a tratar Inazuma.
Dialogue: 0,0:14:21.20,0:14:23.33,Main,,0,0,0,,Tragam todos os medicamentos\Ndo paiol clínico!
Dialogue: 0,0:14:23.33,0:14:24.54,Main,,0,0,0,,Entendido!
Dialogue: 0,0:14:27.59,0:14:31.21,Main,,0,0,0,,Eu nunca mais volto praquele inferno!
Dialogue: 0,0:14:31.21,0:14:35.39,Main,,0,0,0,,Nem eu! Vou repensar minha vida\Ne voltar para minha família!
Dialogue: 0,0:14:35.39,0:14:39.93,Main,,0,0,0,,Agora estamos livres!
Dialogue: 0,0:14:39.93,0:14:42.14,Main,,0,0,0,,Graças a quem?
Dialogue: 0,0:14:42.94,0:14:43.77,Main,,0,0,0,,Digam!
Dialogue: 0,0:14:43.77,0:14:46.02,Main,,0,0,0,,Capitão Buggy!
Dialogue: 0,0:14:49.03,0:14:51.44,Main,,0,0,0,,Não acredito que eles conseguiram.
Dialogue: 0,0:14:51.44,0:14:54.45,Main,,0,0,0,,Marinha? Tragam-me um navio!
Dialogue: 0,0:14:54.45,0:14:57.20,Main,,0,0,0,,Eu vou acabar com eles pessoalmente!
Dialogue: 0,0:14:57.20,0:14:58.16,Main,,0,0,0,,Sim, senhor!
Dialogue: 0,0:14:58.16,0:15:03.42,Main,,0,0,0,,Eles não sabem que\Nainda estão encurralados.
Dialogue: 0,0:15:04.71,0:15:09.09,Main,,0,0,0,,Contra-Almirante! Consertamos\Na bateria danificada por Jinbe!
Dialogue: 0,0:15:09.09,0:15:10.09,Main,,0,0,0,,Muito bem.
Dialogue: 0,0:15:10.76,0:15:13.22,Main,,0,0,0,,Navios, abrir fogo!
Dialogue: 0,0:15:23.98,0:15:25.65,Main,,0,0,0,,Eles começaram a disparar!
Dialogue: 0,0:15:26.44,0:15:27.98,Main,,0,0,0,,Não é possível!
Dialogue: 0,0:15:27.98,0:15:29.57,Main,,0,0,0,,Quantos navios eles têm?!
Dialogue: 0,0:15:31.95,0:15:34.20,Main,,0,0,0,,A frota está vindo pra cá!
Dialogue: 0,0:15:35.74,0:15:37.03,Main,,0,0,0,,Eles nos acertaram!
Dialogue: 0,0:15:38.12,0:15:43.37,Main,,0,0,0,,Embora todos os Vice-Almirantes e superiores\Ntenham sido convocados para Marineford,
Dialogue: 0,0:15:43.37,0:15:46.75,Main,,0,0,0,,a Marinha ainda é Marinha!\NSó possuem os melhores a bordo!
Dialogue: 0,0:15:53.14,0:15:55.18,Main,,0,0,0,,Não veem que é inútil?!
Dialogue: 0,0:15:55.18,0:15:59.89,Main,,0,0,0,,Os Portões da Justiça não vão\Nse abrir para piratas como vocês!
Dialogue: 0,0:16:07.65,0:16:10.20,Main,,0,0,0,,Ah, não! Eu me esqueci disso!
Dialogue: 0,0:16:10.20,0:16:13.53,Main,,0,0,0,,Pelos céus! Não vamos conseguir abri-lo!
Dialogue: 0,0:16:13.53,0:16:17.04,Main,,0,0,0,,Droga! Ficamos sem saída\Ndepois de chegar tão longe!
Dialogue: 0,0:16:17.04,0:16:18.83,Main,,0,0,0,,Você está falando feito eu!
Dialogue: 0,0:16:19.87,0:16:21.29,Main,,0,0,0,,O que vamos fazer, tubarão?!
Dialogue: 0,0:16:21.29,0:16:22.12,Main,,0,0,0,,Vamos cruzá-los!
Dialogue: 0,0:16:22.12,0:16:25.09,Main,,0,0,0,,É impossível! Será um desastre!
Dialogue: 0,0:16:25.09,0:16:28.51,Main,,0,0,0,,Como pode ser tão despreocupado?!
Dialogue: 0,0:16:38.89,0:16:42.52,Main,,0,0,0,,Protejam o navio!\NÉ a nossa prioridade!
Dialogue: 0,0:16:46.11,0:16:49.78,Main,,0,0,0,,Por que só estamos levando tiros?\NEste também é um navio da Marinha!
Dialogue: 0,0:16:49.78,0:16:51.61,Main,,0,0,0,,Atirem de volta, imbecis!
Dialogue: 0,0:16:51.61,0:16:53.32,Main,,0,0,0,,Essa era a minha ideia!
Dialogue: 0,0:16:53.32,0:16:56.54,Main,,0,0,0,,Precisamos contra-atacar, homens!
Dialogue: 0,0:16:56.54,0:16:58.75,Main,,0,0,0,,Entendido, Capitão Buggy!
Dialogue: 0,0:17:07.59,0:17:09.63,Main,,0,0,0,,Sāburusu!
Dialogue: 0,0:17:10.13,0:17:11.34,Main,,0,0,0,,Gomu Gomu no...
Dialogue: 0,0:17:11.34,0:17:12.89,Main,,0,0,0,,...Fūsen!
Dialogue: 0,0:17:12.89,0:17:14.31,Main,,0,0,0,,Que tal?!
Dialogue: 0,0:17:21.23,0:17:22.73,Main,,0,0,0,,Malditos prisioneiros!
Dialogue: 0,0:17:22.73,0:17:27.11,Main,,0,0,0,,Por que ainda seguem para os portões,\Nmesmo sabendo que estão fechados?!
Dialogue: 0,0:17:27.11,0:17:31.24,Main,,0,0,0,,Os portões só vão se abrir\Nde dentro de Impel Down!
Dialogue: 0,0:17:31.24,0:17:33.53,Main,,0,0,0,,Não há outra forma de abri-los!
Dialogue: 0,0:17:39.16,0:17:42.38,Main,,0,0,0,,Continuem atirando! Afundem-nos...
Dialogue: 0,0:17:45.67,0:17:48.97,Main,,0,0,0,,Os Portões da Justiça estão se abrindo!
Dialogue: 0,0:17:48.97,0:17:51.30,Main,,0,0,0,,O quê? O que está havendo?
Dialogue: 0,0:17:51.30,0:17:52.85,Main,,0,0,0,,Por que estão abrindo os portões?!
Dialogue: 0,0:17:55.68,0:17:58.73,Main,,0,0,0,,Estão abertos!
Dialogue: 0,0:18:01.23,0:18:03.82,Main,,0,0,0,,C-Como é possível?!
Dialogue: 0,0:18:03.82,0:18:05.15,Main,,0,0,0,,Será uma armadilha?
Dialogue: 0,0:18:06.40,0:18:10.78,Main,,0,0,0,,Isso! Não sei por quê,\Nmas os portões estão abrindo!
Dialogue: 0,0:18:11.53,0:18:14.37,Main,,0,0,0,,Abriram! Abriram!
Dialogue: 0,0:18:17.62,0:18:19.17,Main,,0,0,0,,O quê?!
Dialogue: 0,0:18:20.92,0:18:23.59,Main,,0,0,0,,Diretor Magellan! Rápido, por favor!
Dialogue: 0,0:18:24.13,0:18:25.67,Main,,0,0,0,,Não! Esperem!
Dialogue: 0,0:18:31.51,0:18:32.97,Main,,0,0,0,,Não pode ser!
Dialogue: 0,0:18:32.97,0:18:35.02,Main,,0,0,0,,Por que os Portões estão se abrindo?!
Dialogue: 0,0:18:38.85,0:18:43.15,Main,,0,0,0,,Tem certeza de que\Ndevemos abrir os portões,
Dialogue: 0,0:18:43.94,0:18:45.61,Main,,0,0,0,,Diretor Magellan?
Dialogue: 0,0:18:45.61,0:18:49.11,Main,,0,0,0,,Claro! Diga-me quando eu estive errado!
Dialogue: 0,0:18:49.11,0:18:51.49,Main,,0,0,0,,Não, não estou duvidando...
Dialogue: 0,0:18:52.58,0:18:54.83,Main,,0,0,0,,Após a passagem do\Nnavio dos prisioneiros,
Dialogue: 0,0:18:54.83,0:18:57.29,Main,,0,0,0,,feche os portões imediatamente! Entendido?
Dialogue: 0,0:18:57.29,0:18:59.04,Main,,0,0,0,,Entendido, senhor!
Dialogue: 0,0:19:03.92,0:19:07.47,Main,,0,0,0,,Não podemos permitir\Nque eles fujam! Fogo!
Dialogue: 0,0:19:09.14,0:19:11.81,Main,,0,0,0,,Isso foi ordem do Magellan?!\NO que deu nele?!
Dialogue: 0,0:19:12.93,0:19:16.48,Main,,0,0,0,,Por que ele está fazendo isso?\NO que aconteceu ao Diretor?
Dialogue: 0,0:19:16.48,0:19:20.81,Main,,0,0,0,,M-Mas acho que não\Nfoi por ordens dele!
Dialogue: 0,0:19:20.81,0:19:24.90,Main,,0,0,0,,Ele estava agora mesmo\Nno cais próximo à entrada principal!
Dialogue: 0,0:19:27.74,0:19:30.62,Thoughts,,0,0,0,,Como assim?! O que aconteceu aqui?!
Dialogue: 0,0:19:32.83,0:19:35.62,Main,,0,0,0,,Controle! O que estão fazendo?!
Dialogue: 0,0:19:35.62,0:19:38.00,Main,,0,0,0,,Quem lhes disse para abrir\Nos Portões da Justiça?!
Dialogue: 0,0:19:38.00,0:19:40.59,Main,,0,0,0,,D-Diretor?!
Dialogue: 0,0:19:43.30,0:19:44.80,Main,,0,0,0,,Ah, não!
Dialogue: 0,0:19:53.31,0:19:55.31,Main,,0,0,0,,É verdade?
Dialogue: 0,0:19:56.52,0:19:58.69,Main,,0,0,0,,O Boninho...
Dialogue: 0,0:20:00.61,0:20:02.36,Main,,0,0,0,,Miserável!
Dialogue: 0,0:20:02.36,0:20:04.11,Main,,0,0,0,,Isso mesmo!
Dialogue: 0,0:20:05.28,0:20:08.07,Main,,0,0,0,,Sou eu!
Dialogue: 0,0:20:09.74,0:20:12.33,Main,,0,0,0,,Enganei vocês de novo!
Dialogue: 0,0:20:12.33,0:20:13.66,Main,,0,0,0,,Ele é um impostor!
Dialogue: 0,0:20:21.21,0:20:23.97,Main,,0,0,0,,Vejam! os portões estão se fechando!
Dialogue: 0,0:20:23.97,0:20:28.85,Main,,0,0,0,,Sim! Se conseguirmos passar,\Nele vai prender a Marinha aqui!
Dialogue: 0,0:20:28.85,0:20:31.43,Main,,0,0,0,,Eu estava com ele na entrada\Nprincipal agora há pouco!
Dialogue: 0,0:20:31.81,0:20:36.65,Main,,0,0,0,,Foi graças ao Boninho que encontramos\No Ivanzinho e conseguimos fugir!
Dialogue: 0,0:20:36.65,0:20:39.44,Main,,0,0,0,,E agora vamos partir sem ele?!
Dialogue: 0,0:20:39.44,0:20:41.03,Main,,0,0,0,,Não temos tempo!
Dialogue: 0,0:20:41.03,0:20:43.03,Main,,0,0,0,,Vamos deixá-lo lá?!
Dialogue: 0,0:20:43.03,0:20:49.37,Main,,0,0,0,,Nós já deixamos centenas de aliados\Nque foram derrotados em batalha!
Dialogue: 0,0:20:49.37,0:20:52.00,Main,,0,0,0,,Quer voltar e enfrentar\NMagellan de novo?!
Dialogue: 0,0:20:52.00,0:20:55.33,Main,,0,0,0,,Quer perder ainda mais aliados?!
Dialogue: 0,0:20:55.33,0:20:59.50,Main,,0,0,0,,Para que os portões fossem abertos,\Nprecisávamos de alguém que ficasse lá!
Dialogue: 0,0:21:03.22,0:21:08.47,Flashbacks,,0,0,0,,Eu sou o mais indicado para a missão!\NEu abrirei os Portões da Justiça!
Dialogue: 0,0:21:11.39,0:21:14.94,Flashbacks,,0,0,0,,E o que vai fazer depois?!
Dialogue: 0,0:21:14.94,0:21:17.77,Flashbacks,,0,0,0,,Que pergunta sem sentido!
Dialogue: 0,0:21:19.52,0:21:23.24,Flashbacks,,0,0,0,,Não diga ao Palhinha até que\Nas comunicações sejam cortadas!
Dialogue: 0,0:21:24.66,0:21:28.66,Flashbacks,,0,0,0,,Em despedidas,\Num Okama nunca diz adeus!
Dialogue: 0,0:21:33.46,0:21:35.67,Main,,0,0,0,,Ainda tem linha...
Dialogue: 0,0:21:38.17,0:21:41.05,Main,,0,0,0,,Um Caracol Comunicador\NBebê tem cobertura reduzida.
Dialogue: 0,0:21:41.05,0:21:44.47,Main,,0,0,0,,Depois que os portões se fecharem,\Nnão vai mais funcionar.
Dialogue: 0,0:21:50.14,0:21:52.31,Main,,0,0,0,,Você ousou se transformar\Nlogo no Diretor?!
Dialogue: 0,0:21:52.31,0:21:55.52,Main,,0,0,0,,Que bom que decorei\Nseu rosto a tempo!
Dialogue: 0,0:21:56.73,0:22:00.57,Flashbacks,,0,0,0,,Acorde, Hannyabal!\NO que aconteceu aqui?!
Dialogue: 0,0:22:00.65,0:22:04.45,Flashbacks,,0,0,0,,D-Diretor! Por favor, me solte!
Dialogue: 0,0:22:04.45,0:22:05.37,Thoughts,,0,0,0,,Toque!
Dialogue: 0,0:22:07.08,0:22:08.79,Main,,0,0,0,,Maldito seja!
Dialogue: 0,0:22:09.74,0:22:11.25,Main,,0,0,0,,Boninho!
Dialogue: 0,0:22:11.25,0:22:13.17,Thoughts,,0,0,0,,Palhinha!
Dialogue: 0,0:22:13.71,0:22:16.25,Main,,0,0,0,,Ei, consegue me ouvir, Boninho?!
Dialogue: 0,0:22:16.84,0:22:19.55,Main,,0,0,0,,Por que você está fazendo isso?!
Dialogue: 0,0:22:20.63,0:22:22.34,Main,,0,0,0,,Igual da outra vez!
Dialogue: 0,0:22:22.34,0:22:27.81,Thoughts,,0,0,0,,Jinbe! Você prometeu não dizer\Nnada até a linha ser cortada!
Dialogue: 0,0:22:29.43,0:22:32.39,Main,,0,0,0,,Nós não íamos fugir juntos?!
Dialogue: 0,0:22:32.98,0:22:36.02,Main,,0,0,0,,Quantas vezes você já não me salvou?!
Dialogue: 0,0:22:39.19,0:22:42.45,Main,,0,0,0,,Se estiver ouvindo,\Nresponda, Boninho!
Dialogue: 0,0:22:42.45,0:22:44.28,Main,,0,0,0,,Então foi isso?!
Dialogue: 0,0:22:44.28,0:22:48.66,Main,,0,0,0,,Aquele Okama ficou lá\Nsozinho para nos salvar!
Dialogue: 0,0:22:48.66,0:22:50.08,Main,,0,0,0,,Boninho!
Dialogue: 0,0:22:50.08,0:22:52.46,Main,,0,0,0,,Irmão Bon! Responda!
Dialogue: 0,0:22:52.46,0:22:54.83,Main,,0,0,0,,Por que não responde?!
Dialogue: 0,0:22:55.25,0:22:56.79,Main,,0,0,0,,Boninho!
Dialogue: 0,0:23:01.38,0:23:03.59,Main,,0,0,0,,Mr. 2!
Dialogue: 0,0:23:03.59,0:23:06.68,Main,,0,0,0,,Mr. 2! Como se atreve?!
Dialogue: 0,0:23:06.68,0:23:09.27,Main,,0,0,0,,Sinto muito por tudo!
Dialogue: 0,0:23:11.85,0:23:12.90,Main,,0,0,0,,Bon-boy!
Dialogue: 0,0:23:12.90,0:23:13.98,Main,,0,0,0,,Fogo!
Dialogue: 0,0:23:14.81,0:23:16.82,Main,,0,0,0,,Eles não podem escapar!
Dialogue: 0,0:23:16.82,0:23:18.44,Main,,0,0,0,,Façam-nos em pedaços!
Dialogue: 0,0:23:18.44,0:23:19.82,Main,,0,0,0,,Bon!
Dialogue: 0,0:23:20.90,0:23:23.03,Main,,0,0,0,,Bon!
Dialogue: 0,0:23:24.78,0:23:28.25,Main,,0,0,0,,Bon, os portões estão se fechando.
Dialogue: 0,0:23:32.21,0:23:34.63,Main,,0,0,0,,Nós... temos que ir.
Dialogue: 0,0:23:41.88,0:23:43.93,Main,,0,0,0,,Obrigado!
Dialogue: 0,0:23:53.44,0:23:56.90,Main,,0,0,0,,Irmão Bon, obrigado!
Dialogue: 0,0:23:56.90,0:24:00.20,Main,,0,0,0,,- Obrigado!\N- Obrigado!
Dialogue: 0,0:24:05.12,0:24:08.00,Main,,0,0,0,,Palhinha!
Dialogue: 0,0:24:08.00,0:24:09.66,Main,,0,0,0,,- Boninho!\N- Palhinha!
Dialogue: 0,0:24:11.17,0:24:14.50,Main,,0,0,0,,Vá salvar seu irmão,\Ncuste o que custar!
Dialogue: 0,0:24:19.84,0:24:25.35,Main,,0,0,0,,Eu tenho certeza de\Nque você vai salvá-lo!
Dialogue: 0,0:24:25.35,0:24:28.10,Main,,0,0,0,,Boninho!
Dialogue: 0,0:24:29.02,0:24:31.06,Main,,0,0,0,,Os portões estão se fechando!
Dialogue: 0,0:24:31.06,0:24:32.90,Main,,0,0,0,,Precisamos afundá-los!
Dialogue: 0,0:24:39.95,0:24:41.91,Flashbacks,,0,0,0,,Há quanto tempo!
Dialogue: 0,0:24:42.87,0:24:45.16,Flashbacks,,0,0,0,,Sim, estou tinindo!
Dialogue: 0,0:24:45.95,0:24:48.87,Flashbacks,,0,0,0,,Dá um tempo!
Dialogue: 0,0:24:53.09,0:24:55.00,Flashbacks,,0,0,0,,Palhinha!
Dialogue: 0,0:24:55.00,0:24:56.63,Flashbacks,,0,0,0,,Eu vim te salvar!
Dialogue: 0,0:24:59.68,0:25:03.51,Flashbacks,,0,0,0,,Em nome da amizade!
Dialogue: 0,0:25:05.06,0:25:06.85,Flashbacks,,0,0,0,,Força!
Dialogue: 0,0:25:07.27,0:25:11.35,Flashbacks,,0,0,0,,Palhinha! Força!
Dialogue: 0,0:25:13.23,0:25:18.53,Flashbacks,,0,0,0,,Em despedidas,\Num Okama nunca diz adeus!
Dialogue: 0,0:25:20.53,0:25:25.54,Main,,0,0,0,,- Boninho!\N- Irmão Bon!
Dialogue: 0,0:25:29.67,0:25:31.42,Main,,0,0,0,,Eu não acredito nisso!
Dialogue: 0,0:25:31.88,0:25:34.09,Main,,0,0,0,,Nós os deixamos escapar!
Dialogue: 0,0:25:34.55,0:25:37.63,Main,,0,0,0,,Se não fosse por ele, nós...
Dialogue: 0,0:25:37.63,0:25:41.47,Main,,0,0,0,,Nós teríamos sido afundados\Nainda dentro dos portões!
Dialogue: 0,0:25:42.26,0:25:49.06,Thoughts,,0,0,0,,A flor da amizade\Nfloresce até no inferno.
Dialogue: 0,0:25:49.06,0:25:52.77,Thoughts,,0,0,0,,Nas areias, onde as ondas vêm e vão,
Dialogue: 0,0:25:52.77,0:25:57.07,Thoughts,,0,0,0,,ela deixa sua pétala como recordação.
Dialogue: 0,0:25:57.45,0:26:03.95,Thoughts,,0,0,0,,Um dia, hei de florescer outra vez,\Ncom meu Caminho Okama!
Dialogue: 0,0:26:05.83,0:26:09.75,Main,,0,0,0,,- Boninho!\N- Irmão Bon!
Dialogue: 0,0:26:09.75,0:26:11.75,Main,,0,0,0,,Bon-boy!
Dialogue: 0,0:26:11.75,0:26:13.50,Main,,0,0,0,,Mr. 2!
Dialogue: 0,0:26:21.43,0:26:24.18,Main,,0,0,0,,Quer dizer alguma coisa antes de morrer?!
Dialogue: 0,0:26:24.56,0:26:26.69,Main,,0,0,0,,É isto que eu queria!
Dialogue: 0,0:26:27.56,0:26:31.23,Thoughts,,0,0,0,,Nós nos reencontraremos\Nno Jardim dos Okamas...
Dialogue: 0,0:26:33.90,0:26:35.40,Main,,0,0,0,,Hoje,
Dialogue: 0,0:26:35.40,0:26:40.66,Main,,0,0,0,,o número de prisioneiros que fugiram\Nda grande prisão submarina, Impel Down,
Dialogue: 0,0:26:40.66,0:26:44.45,Main,,0,0,0,,subiu para um total de 241!
Dialogue: 0,0:26:45.20,0:26:48.38,Main,,0,0,0,,Esta foi a maior falha de segurança\Nda história de Impel Down,
Dialogue: 0,0:26:48.38,0:26:51.29,Main,,0,0,0,,mas a provação ainda não acabou.
Dialogue: 0,0:26:52.71,0:26:55.80,Main,,0,0,0,,A execução pública de\NPortgas D. Ace ocorrerá...
Dialogue: 0,0:26:55.80,0:26:59.18,Main,,0,0,0,,Em 4 horas!