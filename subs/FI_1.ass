Dialogue: 0,0:01:16.42,0:01:18.53,Credits,,0,0,0,,{\pos(1047,408)}Revisão\N{\fs40}RAFAEL
Dialogue: 0,0:00:02.99,0:00:08.38,Main,,0,0,0,,Houve um homem que conquistou tudo o que este mundo tinha a oferecer, o lendário Rei dos Piratas, Gol D. Roger.
Dialogue: 0,0:00:08.38,0:00:13.00,Main,,0,0,0,,Suas últimas palavras fizeram com que legiões de todo o mundo se lançassem aos mares:
Dialogue: 0,0:00:13.00,0:00:14.68,Main,,0,0,0,,Meu tesouro? 
Dialogue: 0,0:00:14.68,0:00:16.22,Main,,0,0,0,,Se quiserem, podem pegá-lo!
Dialogue: 0,0:00:16.22,0:00:17.42,Main,,0,0,0,,Procurem-no! 
Dialogue: 0,0:00:17.42,0:00:19.87,Main,,0,0,0,,Ele contém tudo que este mundo pode oferecer!
Dialogue: 0,0:00:19.87,0:00:22.69,Main,,0,0,0,,Os piratas partiram em busca dos seus sonhos!
Dialogue: 0,0:00:22.69,0:00:25.35,Main,,0,0,0,,Assim começou a Grande Era dos Piratas!!
Dialogue: 0,0:00:25.35,0:00:29.31,We Go lyrics,,0,0,0,,Não consigo ficar parado! Não consigo parar!
Dialogue: 0,0:00:29.31,0:00:33.81,We Go lyrics,,0,0,0,,O amanhecer ainda não chegou, estou cansado de esperar!
Dialogue: 0,0:00:33.81,0:00:37.48,We Go lyrics,,0,0,0,,Um, dois, Sunshine quatro... We Go!
Dialogue: 0,0:00:38.97,0:00:43.05,We Go lyrics,,0,0,0,,Agora levante nossa bandeira para o Amanhecer do Romantismo.
Dialogue: 0,0:00:44.41,0:00:49.74,We Go lyrics,,0,0,0,,Deixe as ondas quebrarem, elas vão nos acordar de repente.
Dialogue: 0,0:00:49.74,0:00:54.28,We Go lyrics,,0,0,0,,Se vamos para um mundo incrível,
Dialogue: 0,0:00:54.28,0:00:58.79,We Go lyrics,,0,0,0,,você terá que ser durão.
Dialogue: 0,0:00:59.11,0:01:01.73,We Go lyrics,,0,0,0,,Se destacar muito, isso é crime?
Dialogue: 0,0:01:01.73,0:01:04.62,We Go lyrics,,0,0,0,,Ser procurado significa ser um vencedor!
Dialogue: 0,0:01:04.62,0:01:10.50,We Go lyrics,,0,0,0,,A liberdade é a nossa única regra!
Dialogue: 0,0:01:10.50,0:01:15.99,We Go lyrics,,0,0,0,,Esqueça nossas preocupações, deixe o vento soprar.
Dialogue: 0,0:01:15.99,0:01:18.53,We Go lyrics,,0,0,0,,Tenho certeza de que seremos os primeiros a encontrar One Piece!
Dialogue: 0,0:01:18.53,0:01:22.66,We Go lyrics,,0,0,0,,Nossos corações sonham além dos limites...
Dialogue: 0,0:01:22.66,0:01:26.93,We Go lyrics,,0,0,0,,então nunca vamos acordá-los.
Dialogue: 0,0:01:26.93,0:01:29.57,We Go lyrics,,0,0,0,,Eu não consigo ficar parado! Eu não consigo parar!
Dialogue: 0,0:01:29.57,0:01:33.54,We Go lyrics,,0,0,0,,O amanhecer ainda não chegou, estou cansado de esperar!
Dialogue: 0,0:01:33.54,0:01:37.33,We Go lyrics,,0,0,0,,Um, dois, Sunshine quatro... We Go!
Dialogue: 0,0:01:38.76,0:01:44.72,We Go lyrics,,0,0,0,,Nós... chegamos até aqui.
Dialogue: 0,0:01:44.72,0:01:47.62,We Go lyrics,,0,0,0,,Nós iremos... onde quer que nossos sonhos nos levem,
Dialogue: 0,0:01:47.62,0:01:52.70,We Go lyrics,,0,0,0,,e não deixaremos ninguém para trás.
Dialogue: 0,0:01:52.70,0:01:55.30,We Go lyrics,,0,0,0,,Nós iremos com todo o nosso coração, isso é uma promessa.
Dialogue: 0,0:01:55.30,0:01:59.47,We Go lyrics,,0,0,0,,Naquele dia em que nossos sonhos começaram,
Dialogue: 0,0:01:59.47,0:02:03.72,We Go lyrics,,0,0,0,,estabelecemos nossos objetivos e eles nunca mudaram!
Dialogue: 0,0:02:03.72,0:02:06.24,We Go lyrics,,0,0,0,,Não consigo ficar parado! Não consigo parar!
Dialogue: 0,0:02:06.24,0:02:10.61,We Go lyrics,,0,0,0,,O sol em meu coração nunca se porá!
Dialogue: 0,0:02:10.61,0:02:13.38,We Go lyrics,,0,0,0,,Um, dois, Sunshine...
Dialogue: 0,0:02:14.78,0:02:17.57,We Go lyrics,,0,0,0,,Um, dois, Sunshine...
Dialogue: 0,0:02:18.75,0:02:24.82,We Go lyrics,,0,0,0,,Um, dois, Sunshine, quatro... We Go!
Dialogue: 0,0:02:27.27,0:02:30.04,We Go lyrics,,0,0,0,,We Go!
Dialogue: 0,0:02:30.04,0:02:37.55,Title,,0,0,0,,Descendo as profundezas! Os Piratas do Caribou e o Kraken!
Dialogue: 0,0:02:39.62,0:02:45.33,Main,,0,0,0,,Irmão, está difícil de cavar! \NPorque esta ilha é composta basicamente de raízes!
Dialogue: 0,0:02:39.72,0:02:43.65,Captions,,0,0,180,,{\fad(800,500)}Arquipélago Sabaody
Dialogue: 0,0:02:45.33,0:02:48.20,Main,,0,0,0,,Por favor, perdoe-nos! Não nos enterre!
Dialogue: 0,0:02:48.20,0:02:50.73,Main,,0,0,0,,Eu faço qualquer coisa,\Nmas não me mate!
Dialogue: 0,0:02:50.73,0:02:55.17,Main,,0,0,0,,O Capitão Black nos forçou a fazer isto!
Dialogue: 0,0:02:56.14,0:02:59.71,Main,,0,0,0,,Quando nos juntamos a eles,
Dialogue: 0,0:02:59.71,0:03:03.24,Main,,0,0,0,,Nós queríamos matar os Chapéus de Palha,
Dialogue: 0,0:03:04.38,0:03:07.01,Main,,0,0,0,,de dentro do bando,
Dialogue: 0,0:03:07.01,0:03:12.55,Main,,0,0,0,,e ganhar toda aquela fortuna em recompensas!
Dialogue: 0,0:03:15.72,0:03:17.26,Main,,0,0,0,,Drip!
Dialogue: 0,0:03:17.26,0:03:21.86,Main,,0,0,0,,Ei, pare com isso! Ele vai morrer!\NVocê usa uma Akuma no Mi?
Dialogue: 0,0:03:21.86,0:03:24.37,Main,,0,0,0,,Não faça isso!
Dialogue: 0,0:03:28.10,0:03:30.00,Main,,0,0,0,,Hã, como assim? É um Logia?!
Dialogue: 0,0:03:32.71,0:03:34.61,Main,,0,0,0,,Mas vejam o que aconteceu!
Dialogue: 0,0:03:34.61,0:03:39.71,Main,,0,0,0,,Achei que ele só estava diferente,\Npois não o via há dois anos...
Dialogue: 0,0:03:39.71,0:03:45.65,Main,,0,0,0,,Mas quem diria! Este Chapéu de Palha\Nnão passava de um impostor!
Dialogue: 0,0:03:45.65,0:03:48.92,Main,,0,0,0,,Acham que Deus vai perdoá-los, Coribou?
Dialogue: 0,0:03:48.92,0:03:50.36,Main,,0,0,0,,Cavando! Cavando!
Dialogue: 0,0:03:50.36,0:03:53.66,Main,,0,0,0,,Isso mesmo! Vamos enterrá-los!
Dialogue: 0,0:03:53.66,0:03:59.83,Main,,0,0,0,,Deus! Permita-nos enterrar esses idiotas!
Dialogue: 0,0:04:00.80,0:04:02.14,Main,,0,0,0,,Não! Por favor, não nos mate!
Dialogue: 0,0:04:02.14,0:04:07.98,Main,,0,0,0,,Mas eu vi o verdadeiro Chapéu\Nde Palha com meus próprios olhos!
Dialogue: 0,0:04:09.57,0:04:13.93,Captions,Sign,0,0,180,,{\fad(800,500)}Ponto Onde se Reuniram os Falsos Chapéus de Palha
Dialogue: 0,0:04:09.90,0:04:14.03,Main,Sentoumaru,0,0,0,,{\an8}Eu disse que eu não tinha escolha!
Dialogue: 0,0:04:14.65,0:04:17.65,Main,,0,0,0,,Rayleigh, o Rei das Trevas, nos atacou!
Dialogue: 0,0:04:17.65,0:04:21.46,Main,,0,0,0,,O que poderíamos fazer contra alguém\Nque duelou com o Tio Kizaru?
Dialogue: 0,0:04:22.29,0:04:26.49,Main,,0,0,0,,O bando dos irmãos Caribou\Ne alguns dos impostores
Dialogue: 0,0:04:26.96,0:04:29.93,Main,,0,0,0,,conseguiram fugir.
Dialogue: 0,0:04:29.93,0:04:31.97,Main,,0,0,0,,Capturamos todos os outros.
Dialogue: 0,0:04:31.97,0:04:36.87,Main,,0,0,0,,Mas dois Pacifistas foram severamente danificados\Npelos Chapéus de Palha autênticos.
Dialogue: 0,0:04:36.87,0:04:41.14,Main,,0,0,0,,Um deles era o protótipo\Nque os encurralou há dois anos.
Dialogue: 0,0:04:41.14,0:04:43.91,Main,,0,0,0,,Obviamente, eles não enfraqueceram.
Dialogue: 0,0:04:43.91,0:04:46.38,Main,,0,0,0,,Portanto, quem mudou foram eles.
Dialogue: 0,0:04:47.18,0:04:51.75,Main,,0,0,0,,Eles ficaram bem mais fortes\Nnestes dois anos!
Dialogue: 0,0:04:52.89,0:04:57.59,Main,,0,0,0,,Avise ao QG no Novo Mundo.
Dialogue: 0,0:04:57.59,0:05:02.00,Main,,0,0,0,,Os Chapéus de Palha voltaram com tudo!
Dialogue: 0,0:05:06.67,0:05:09.27,Main,,0,0,0,,Eles foram num piscar de olhos.
Dialogue: 0,0:05:09.27,0:05:13.44,Main,,0,0,0,,Monkey e os meninos\Nficaram mais fortes...
Dialogue: 0,0:05:13.71,0:05:15.08,Main,,0,0,0,,Estava assistindo?
Dialogue: 0,0:05:15.08,0:05:16.71,Main,,0,0,0,,Claro. Sou fã deles.
Dialogue: 0,0:05:17.41,0:05:21.15,Main,,0,0,0,,O que se passa\Npela sua cabeça, Ray?
Dialogue: 0,0:05:21.15,0:05:25.25,Main,,0,0,0,,Hm? Bom...
Dialogue: 0,0:05:25.25,0:05:26.95,Flashbacks,,0,0,0,,Ei, belo barco!
Dialogue: 0,0:05:27.45,0:05:31.73,Flashbacks,,0,0,0,,Eu o roubei. Minha casa pegou fogo,\Ne resolvi morar nele.
Dialogue: 0,0:05:31.73,0:05:33.96,Flashbacks,,0,0,0,,Sério? E qual é o seu nome?
Dialogue: 0,0:05:33.96,0:05:35.33,Flashbacks,,0,0,0,,Rayleigh.
Dialogue: 0,0:05:36.23,0:05:41.00,Flashbacks,,0,0,0,,Meu nome é Roger! Acho que este\Nencontro é obra do destino, Rayleigh!
Dialogue: 0,0:05:41.30,0:05:44.71,Flashbacks,,0,0,0,,Quer virar o mundo ao avesso comigo?
Dialogue: 0,0:05:45.11,0:05:47.81,Flashbacks,,0,0,0,,Hã? O mundo?
Dialogue: 0,0:05:48.78,0:05:52.38,Flashbacks,,0,0,0,,De onde você surgiu, hein? Some daqui!
Dialogue: 0,0:05:54.38,0:05:58.69,Main,,0,0,0,,Talvez nada neste mundo\Naconteça por acaso...
Dialogue: 0,0:05:58.69,0:06:01.72,Main,,0,0,0,,Tudo tem seu motivo.
Dialogue: 0,0:06:02.99,0:06:06.09,Main,,0,0,0,,Nosso destino vai se moldando aos poucos.
Dialogue: 0,0:06:06.09,0:06:09.66,Main,,0,0,0,,A verdade é que aquele\Nchapéu cai bem no Luffy,
Dialogue: 0,0:06:09.66,0:06:13.70,Main,,0,0,0,,melhor do que em qualquer um.
Dialogue: 0,0:06:13.70,0:06:17.24,Main,,0,0,0,,Acho que eu quero viver um pouco mais.
Dialogue: 0,0:06:17.24,0:06:20.57,Captions,,0,0,0,,No fundo do mar,\Npróximo ao Arquipélago Sabaody\NJá estamos bem distantes da superfície!
Dialogue: 0,0:06:20.57,0:06:26.18,Main,,0,0,0,,Que vista! Submarinos não têm\Njanelas tão largas assim!
Dialogue: 0,0:06:26.18,0:06:28.52,Main,,0,0,0,,Estamos submergindo mais e mais!
Dialogue: 0,0:06:29.08,0:06:32.02,Main,,0,0,0,,Estou preocupado de sermos inundados!
Dialogue: 0,0:06:32.02,0:06:35.76,Main,,0,0,0,,Sinto como se estivéssemos deixando o mundo\Nhabitado. Que nervoso!
Dialogue: 0,0:06:35.76,0:06:40.76,Main,,0,0,0,,V-Vamos mesmo conseguir emergir, depois?
Dialogue: 0,0:06:40.76,0:06:43.10,Main,,0,0,0,,N-Não que eu esteja com medo, mas...
Dialogue: 0,0:06:43.10,0:06:45.40,Main,,0,0,0,,O mar é tão lindo!
Dialogue: 0,0:06:46.33,0:06:48.77,Main,,0,0,0,,Vejam só!
Dialogue: 0,0:06:51.44,0:06:53.37,Main,,0,0,0,,Árvores... Aliás, raízes!
Dialogue: 0,0:06:53.37,0:06:59.55,Main,,0,0,0,,É mesmo! Sabaody é composta\Nde manguezais gigantes!
Dialogue: 0,0:06:59.55,0:07:01.98,Main,,0,0,0,,É impressionante a beleza da natureza!
Dialogue: 0,0:07:01.98,0:07:03.85,Main,,0,0,0,,Já vi tudo isso.
Dialogue: 0,0:07:03.85,0:07:08.26,Main,,0,0,0,,Porque foi subir no navio errado!\NCala a boca, estraga-prazeres!
Dialogue: 0,0:07:08.89,0:07:12.73,Main,,0,0,0,,Não acredito que essas raízes\Ndescem até o fundo do mar!
Dialogue: 0,0:07:13.43,0:07:15.60,Main,,0,0,0,,Elas são colossais!\NNão tenho palavras para descrevê-las!
Dialogue: 0,0:07:15.60,0:07:19.30,Main,,0,0,0,,Ei, Chopper... Tem alguma\Ncoisa atrás daquela árvore!
Dialogue: 0,0:07:19.30,0:07:19.93,Main,,0,0,0,,O quê?!
Dialogue: 0,0:07:21.27,0:07:23.94,Main,,0,0,0,,Nossa, é enorme!
Dialogue: 0,0:07:23.94,0:07:29.44,Main,,0,0,0,,Que maneiro! Uma aventura submarina!\NÉ como um sonho realizado!
Dialogue: 0,0:07:29.44,0:07:31.61,Main,,0,0,0,,Ih, peixes!
Dialogue: 0,0:07:31.61,0:07:32.91,Main,,0,0,0,,Acho que eu consigo pegar!
Dialogue: 0,0:07:34.21,0:07:37.05,Main,,0,0,0,,Os peixes aqui também parecem deliciosos.
Dialogue: 0,0:07:38.72,0:07:40.42,Main,,0,0,0,,Parem com isso, seus imbecis!
Dialogue: 0,0:07:40.42,0:07:43.42,Main,,0,0,0,,E se a bolha de sabão estourar?!
Dialogue: 0,0:07:43.42,0:07:45.43,Main,,0,0,0,,Façam isso de novo e eu mato vocês!
Dialogue: 0,0:07:45.43,0:07:49.03,Main,,0,0,0,,Nami, que tal nos dizer o que podemos\Nou não fazer no navio revestido
Dialogue: 0,0:07:49.03,0:07:50.96,Main,,0,0,0,,antes que os idiotas aprontem de novo?
Dialogue: 0,0:07:51.47,0:07:55.77,Main,,0,0,0,,Claro, Sanji! O Senhor Rayleigh\Nme passou instruções.
Dialogue: 0,0:07:55.77,0:07:57.77,Main,,0,0,0,,Pessoal, escutem bem...
Dialogue: 0,0:07:57.77,0:08:00.84,Main,,0,0,0,,Ah, ela se mexe!\NUma linda mulher de verdade!
Dialogue: 0,0:08:00.84,0:08:02.14,Main,,0,0,0,,Sanji!
Dialogue: 0,0:08:02.41,0:08:03.88,Main,,0,0,0,,Vai estourar! Vai estourar!
Dialogue: 0,0:08:03.88,0:08:06.35,Main,,0,0,0,,Como um nariz sangrando\Npode dar tanto impulso?!
Dialogue: 0,0:08:07.35,0:08:08.48,Main,,0,0,0,,O quê?!
Dialogue: 0,0:08:08.62,0:08:10.78,Main,,0,0,0,,Sanji tá no mar aberto!
Dialogue: 0,0:08:10.78,0:08:14.99,Main,,0,0,0,,Sanji! Volta aqui!
Dialogue: 0,0:08:15.96,0:08:17.72,Main,,0,0,0,,Na água,eu fico fraco...
Dialogue: 0,0:08:17.72,0:08:20.19,Main,,0,0,0,,Aguenta firme!
Dialogue: 0,0:08:21.86,0:08:25.07,Main,,0,0,0,,O que aconteceu contigo, Sanji?
Dialogue: 0,0:08:25.07,0:08:28.17,Main,,0,0,0,,Parece até que está mais vulnerável a mulheres!
Dialogue: 0,0:08:28.17,0:08:29.70,Main,,0,0,0,,Você não é assim!
Dialogue: 0,0:08:29.70,0:08:36.44,Main,,0,0,0,,Pobrezinho... O que o mulherengo Sanji\Npassou nestes últimos dois anos?
Dialogue: 0,0:08:36.44,0:08:40.55,Main,,0,0,0,,Se continuar assim, ele vai\Nmorrer de hemorragia nasal
Dialogue: 0,0:08:40.55,0:08:43.02,Main,,0,0,0,,quando encontrar as sereias\Nque tanto quer ver.
Dialogue: 0,0:08:43.15,0:08:46.62,Main,,0,0,0,,Vamos precisar de transfusões de sangue\Nna Ilha dos Homens-Peixe.
Dialogue: 0,0:08:46.62,0:08:50.82,Main,,0,0,0,,Será que os Homens-Peixe e as Sereias\Npossuem o mesmo tipo sanguíneo dos humanos?
Dialogue: 0,0:08:50.82,0:08:55.10,Main,,0,0,0,,Ou seja, a bolha que reveste\No Sunny tem as mesmas propriedades
Dialogue: 0,0:08:55.10,0:08:59.93,Main,,0,0,0,,das bolhas que acabamos de ver\Nno Arquipélago Sabaody.
Dialogue: 0,0:08:59.93,0:09:03.10,Main,,0,0,0,,Pare de analisar a bolha\Ntão calmamente!
Dialogue: 0,0:09:03.10,0:09:06.11,Main,,0,0,0,,A Robin tem razão.\NÉ essencialmente a mesma coisa.
Dialogue: 0,0:09:06.11,0:09:09.81,Main,,0,0,0,,Ela possui um limiar de elasticidade,\Na partir do qual é possível atravessá-la.
Dialogue: 0,0:09:09.81,0:09:16.15,Main,,0,0,0,,Ou seja, se dispararmos um canhão\Ncontra alguma criatura que nos atacar,
Dialogue: 0,0:09:16.15,0:09:17.92,Main,,0,0,0,,a bolha não se rompe.
Dialogue: 0,0:09:17.92,0:09:21.79,Main,,0,0,0,,Hã? Então o que pode\Nfazer ela se romper?
Dialogue: 0,0:09:21.79,0:09:26.39,Main,,0,0,0,,Se por acaso muitos buracos forem\Nabertos de uma vez só, ela vai romper.
Dialogue: 0,0:09:26.39,0:09:27.79,Main,,0,0,0,,Por exemplo:
Dialogue: 0,0:09:27.79,0:09:31.63,Main,,0,0,0,,Se ela for mordida pelas presas de um\NRei dos Mares, é o fim.
Dialogue: 0,0:09:33.50,0:09:36.34,Main,,0,0,0,,Está vindo pela nossa popa!
Dialogue: 0,0:09:36.34,0:09:38.00,Main,,0,0,0,,Veio outro maior e o mordeu... Ufa!
Dialogue: 0,0:09:38.00,0:09:43.51,Main,,0,0,0,,Ou se o próprio navio quebrar,\Ncolidindo com uma rocha ou um fosso,
Dialogue: 0,0:09:43.51,0:09:49.52,Main,,0,0,0,,E aí lascas do mastro e do assoalho\Npodem rompê-la, o que também é perigoso.
Dialogue: 0,0:09:49.52,0:09:53.19,Main,,0,0,0,,Temos que tomar cuidado com\Nas criaturas e obstáculos no mar.
Dialogue: 0,0:09:53.19,0:09:56.96,Main,,0,0,0,,De resto, se não fizermos nenhuma\Nidiotice a bordo, podemos ficar tranquilos.
Dialogue: 0,0:09:56.96,0:10:00.56,Main,,0,0,0,,Entendi! É mais resistente do que pensei!
Dialogue: 0,0:10:00.56,0:10:05.67,Main,,0,0,0,,Mas de todos os navios que seguem\Npara a Ilha dos Homens-Peixe,
Dialogue: 0,0:10:05.67,0:10:08.50,Main,,0,0,0,,70% deles acabam afundando.
Dialogue: 0,0:10:09.57,0:10:11.54,Main,,0,0,0,,O que vai acontecer?
Dialogue: 0,0:10:12.07,0:10:16.58,Main,,0,0,0,,Com o meu Gatling Gun\Neu consigo pegar um cardume inteiro!
Dialogue: 0,0:10:16.58,0:10:20.38,Main,,0,0,0,,Então vamos ver quem consegue\Npegar mais peixes!
Dialogue: 0,0:10:20.78,0:10:23.92,Main,,0,0,0,,Não ouviram nada do\Nque a Nami disse?!
Dialogue: 0,0:10:23.92,0:10:26.12,Main,,0,0,0,,"Buracos demais" não pode!
Dialogue: 0,0:10:26.45,0:10:29.79,Main,,0,0,0,,Se tentarem isso de novo, eu mato vocês!
Dialogue: 0,0:10:29.79,0:10:34.26,Main,,0,0,0,,Droga! Como o Hachi disse que ia nos guiar\Naté a Ilha dos Homens-Peixe,
Dialogue: 0,0:10:34.26,0:10:37.30,Main,,0,0,0,,achei que ia ser uma viagem tranquila!
Dialogue: 0,0:10:37.30,0:10:38.50,Main,,0,0,0,,Ah, é!
Dialogue: 0,0:10:38.50,0:10:41.63,Main,,0,0,0,,Elas me deram comida à beça!
Dialogue: 0,0:10:41.63,0:10:44.67,Main,,0,0,0,,Como o Sanji tá doente,\Nvamos lanchar, galera!
Dialogue: 0,0:10:45.10,0:10:46.77,Main,,0,0,0,,Estou morrendo de fome!
Dialogue: 0,0:10:48.27,0:10:49.94,Main,,0,0,0,,Meus ossos estão roncando!
Dialogue: 0,0:10:50.41,0:10:53.95,Main,,0,0,0,,Nami, o navio já está estabilizado?
Dialogue: 0,0:10:53.95,0:10:58.48,Main,,0,0,0,,Sim. Agora é só seguir\Nna corrente marítima.
Dialogue: 0,0:10:58.89,0:11:03.66,Main,,0,0,0,,Queria contar uma coisa pra vocês.
Dialogue: 0,0:11:03.66,0:11:05.79,Main,,0,0,0,,...os segredos do robô?!
Dialogue: 0,0:11:05.79,0:11:08.23,Main,,0,0,0,,Não, infelizmente...
Dialogue: 0,0:11:08.23,0:11:10.26,Main,,0,0,0,,Infelizmente, não é sobre isso-robô.
Dialogue: 0,0:11:10.26,0:11:12.83,Main,,0,0,0,,Nossa, maneiro! Ele fala robotês!
Dialogue: 0,0:11:13.93,0:11:18.84,Main,,0,0,0,,Hachi nos disse que mostraria o caminho\Npara a Ilha dos Homens-Peixe,
Dialogue: 0,0:11:18.84,0:11:21.51,Main,,0,0,0,,mas ele ficou ferido em Sabaody
Dialogue: 0,0:11:21.51,0:11:23.94,Main,,0,0,0,,e está em tratamento médico na Ilha dos\NHomens-Peixe.
Dialogue: 0,0:11:24.68,0:11:27.58,Main,,0,0,0,,As condições dele e do Duval\Nse devem ao mesmo motivo.
Dialogue: 0,0:11:27.58,0:11:32.19,Main,,0,0,0,,Ele estava protegendo o Thousand Sunny.
Dialogue: 0,0:11:32.19,0:11:35.96,Main,,0,0,0,,Um ano atrás, a Marinha descobriu o Sunny.
Dialogue: 0,0:11:35.96,0:11:40.03,Main,,0,0,0,,Os dois travaram um violenta disputa\Ne ficaram fora de combate.
Dialogue: 0,0:11:40.03,0:11:44.73,Main,,0,0,0,,Hã? Então como é que\No navio continua inteiro?
Dialogue: 0,0:11:45.23,0:11:48.07,Main,,0,0,0,,Mais uma pessoa lutou com eles.
Dialogue: 0,0:11:48.07,0:11:53.24,Main,,0,0,0,,O homem que nos separou há dois anos.
Dialogue: 0,0:11:55.54,0:11:59.98,Main,,0,0,0,,O Shichibukai Bartholomew Kuma!
Dialogue: 0,0:11:59.98,0:12:06.59,Main,,0,0,0,,Quando cheguei ao Sunny há alguns dias,\Nnão acreditei no que vi...
Dialogue: 0,0:12:07.52,0:12:09.26,Flashbacks,,0,0,0,,Estava à sua espera.
Dialogue: 0,0:12:10.69,0:12:12.93,Flashbacks,,0,0,0,,O que você faz aqui?!
Dialogue: 0,0:12:13.96,0:12:17.30,Flashbacks,,0,0,0,,Missão cumprida.
Dialogue: 0,0:12:20.57,0:12:24.40,Main,,0,0,0,,O Sunny não possui um arranhão sequer.
Dialogue: 0,0:12:24.40,0:12:27.67,Main,,0,0,0,,E Rayleigh depois me disse...
Dialogue: 0,0:12:28.11,0:12:31.18,Flashbacks,,0,0,0,,Eu trabalho para o\NExército Revolucionário.
Dialogue: 0,0:12:31.18,0:12:34.75,Flashbacks,,0,0,0,,E justamente devido a esta relação,\Nquero que os Chapéus de Palha fujam daqui.
Dialogue: 0,0:12:34.75,0:12:38.62,Main,,0,0,0,,Acho que vocês meio que já imaginavam,
Dialogue: 0,0:12:38.62,0:12:41.35,Main,,0,0,0,,mas o cara salvou nossas vidas!
Dialogue: 0,0:12:41.35,0:12:44.66,Main,,0,0,0,,E depois que desaparecemos da ilha,
Dialogue: 0,0:12:44.66,0:12:48.29,Main,,0,0,0,,Kuma foi visitar o Rayleigh\Ne contou a ele que...
Dialogue: 0,0:12:48.29,0:12:52.57,Flashbacks,,0,0,0,,Não me resta muito tempo.
Dialogue: 0,0:12:52.57,0:12:56.70,Main,,0,0,0,,Eu não sei o que o fez\Nobedecer à Marinha,
Dialogue: 0,0:12:56.70,0:12:58.60,Main,,0,0,0,,mas ele concordou em ser cobaia
Dialogue: 0,0:12:58.60,0:13:01.27,Main,,0,0,0,,e deixou que o modificassem\Naté torná-lo num ciborgue.
Dialogue: 0,0:13:01.27,0:13:03.48,Main,,0,0,0,,Quando chegou a Guerra dos Maiorais,
Dialogue: 0,0:13:03.48,0:13:07.25,Main,,0,0,0,,ele já não tinha nenhum\Nresquício de personalidade.
Dialogue: 0,0:13:07.48,0:13:10.15,Main,,0,0,0,,Mas ele não tinha como saber o que faríamos,
Dialogue: 0,0:13:10.15,0:13:14.05,Main,,0,0,0,,depois que fomos separados!
Dialogue: 0,0:13:14.42,0:13:18.06,Main,,0,0,0,,E mesmo perdendo a personalidade,\Nele esperou no navio?
Dialogue: 0,0:13:18.32,0:13:21.96,Main,,0,0,0,,Ele fez o Dr. Vegapunk, que o modificou,
Dialogue: 0,0:13:22.43,0:13:26.57,Main,,0,0,0,,prometer que programaria uma diretriz nele.
Dialogue: 0,0:13:26.93,0:13:31.04,Main,,0,0,0,,"Até o dia em que um dos\NChapéus do Palha regressasse,
Dialogue: 0,0:13:31.04,0:13:33.24,Main,,0,0,0,,ele deveria defender o navio pirata."
Dialogue: 0,0:13:33.84,0:13:37.44,Main,,0,0,0,,Por isso, por dois anos,\Nmesmo sem saber o porquê,
Dialogue: 0,0:13:37.98,0:13:39.75,Main,,0,0,0,,mesmo tendo se tornado uma arma humana,
Dialogue: 0,0:13:39.75,0:13:43.15,Main,,0,0,0,,ele cumpriu a missão que deu\Na si mesmo quando ainda era humano.
Dialogue: 0,0:13:43.15,0:13:45.82,Main,,0,0,0,,Que plano mais complicado...
Dialogue: 0,0:13:45.82,0:13:47.72,Main,,0,0,0,,Por que ele faria isso por nós?
Dialogue: 0,0:13:47.92,0:13:50.42,Main,,0,0,0,,Relação... Exército Revolucionário...
Dialogue: 0,0:13:50.42,0:13:55.39,Main,,0,0,0,,Tudo isso só me lembra do\Npai do Luffy, o líder dos Revolucionários.
Dialogue: 0,0:13:56.33,0:13:58.76,Main,,0,0,0,,Eu nem conheço meu pai direito.
Dialogue: 0,0:13:58.76,0:14:02.33,Main,,0,0,0,,Então, no fim das contas,\Naquele urso era um cara do bem?
Dialogue: 0,0:14:02.77,0:14:04.20,Thoughts,,0,0,0,,Kuma...
Dialogue: 0,0:14:04.20,0:14:13.45,Main,,0,0,0,,Sem sombra de dúvidas, foi graças a ele\Nque pudemos tirar dois anos de férias.
Dialogue: 0,0:14:14.28,0:14:20.79,Main,,0,0,0,,Não temos nem como perguntar a ele,\Nmas vamos nos lembrar disso.
Dialogue: 0,0:14:20.79,0:14:28.13,Main,,0,0,0,,Bartholomew Kuma acabou sendo um\Ndos nossos maiores benfeitores.
Dialogue: 0,0:14:28.13,0:14:34.40,Main,,0,0,0,,Mas mesmo que nos reencontremos, ele agora é\Nsó uma arma humana desprovida de coração.
Dialogue: 0,0:14:34.40,0:14:37.30,Main,,0,0,0,,Eu fico grato pelo que ele fez,\Nmas a conta ainda não bate.
Dialogue: 0,0:14:37.30,0:14:40.11,Main,,0,0,0,,Espero que a gente descubra\Nos motivos dele, um dia.
Dialogue: 0,0:14:40.21,0:14:41.54,Main,,0,0,0,,Isso era tudo que eu tinha para dizer.
Dialogue: 0,0:14:41.97,0:14:44.11,Main,,0,0,0,,Ah, você acordou, Sanji!
Dialogue: 0,0:14:44.11,0:14:46.65,Main,,0,0,0,,Vem comer! É culinária da Ilha das Mulheres!
Dialogue: 0,0:14:46.65,0:14:51.98,Main,,0,0,0,,Ilha das Mulheres?\NE o Kuma era nosso aliado?
Dialogue: 0,0:14:51.98,0:14:54.79,Main,,0,0,0,,Fazem ideia de onde eu\Nfiquei esses dois anos?
Dialogue: 0,0:14:54.79,0:14:59.66,Main,,0,0,0,,Que treino você fez nessa ilha\Nparadisíaca cheia de mulheres, Luffy?
Dialogue: 0,0:14:59.66,0:15:03.33,Main,,0,0,0,,Ei, ei, ei, Sanji, quer cantar comigo?
Dialogue: 0,0:15:03.33,0:15:06.13,Main,,0,0,0,,Pare de tentar me animar!\NEu me sinto um lixo!
Dialogue: 0,0:15:06.13,0:15:09.23,Main,,0,0,0,,Irmão, lá está o Chapéu de Palha.
Dialogue: 0,0:15:09.23,0:15:14.64,Main,,0,0,0,,Estou vendo, imbecil!
Dialogue: 0,0:15:14.64,0:15:18.08,Main,,0,0,0,,E desta vez, eu vou mesmo\Nembarcar no navio deles!
Dialogue: 0,0:15:18.08,0:15:20.48,Main,,0,0,0,,A gente já tá a quantos metros\Nabaixo da superfície?
Dialogue: 0,0:15:20.48,0:15:23.85,Main,,0,0,0,,Está ficando um breu danado...
Dialogue: 0,0:15:23.85,0:15:25.75,Main,,0,0,0,,Passamos da zona eufótica,
Dialogue: 0,0:15:25.75,0:15:28.22,Main,,0,0,0,,e estamos no final da zona mesopelágica.
Dialogue: 0,0:15:28.72,0:15:30.66,Main,,0,0,0,,Já devemos ter passado de mais de mil metros.
Dialogue: 0,0:15:31.86,0:15:32.99,Main,,0,0,0,,Que silêncio...
Dialogue: 0,0:15:32.99,0:15:35.73,Main,,0,0,0,,É bem diferente de um submarino.
Dialogue: 0,0:15:36.09,0:15:38.56,Main,,0,0,0,,É como se estivéssemos voando no céu.
Dialogue: 0,0:15:38.56,0:15:40.47,Main,,0,0,0,,Uma baleia! Uma baleia!
Dialogue: 0,0:15:40.47,0:15:42.17,Main,,0,0,0,,Laboon! Laboon!
Dialogue: 0,0:15:42.17,0:15:44.90,Main,,0,0,0,,Não, é o velho Barba Branca!
Dialogue: 0,0:15:44.90,0:15:49.21,Main,,0,0,0,,Tem um objeto às seis horas.\NSerá que é alguma criatura?
Dialogue: 0,0:15:49.21,0:15:52.58,Main,,0,0,0,,Vocês estão prontos, cambada?!
Dialogue: 0,0:15:52.58,0:15:54.21,Main,,0,0,0,,Sim, irmão!
Dialogue: 0,0:15:54.21,0:15:55.41,Main,,0,0,0,,Sim, sim!
Dialogue: 0,0:15:55.41,0:15:58.25,Main,,0,0,0,,O alvo está bem à nossa frente!
Dialogue: 0,0:15:58.25,0:16:04.69,Main,,0,0,0,,É mais fácil destruir o navio deles\Ne deixar o mar engoli-los!
Dialogue: 0,0:16:04.69,0:16:09.56,Main,,0,0,0,,Mas aí não teria graça,\Npois ninguém saberia quem fez isso!
Dialogue: 0,0:16:09.56,0:16:12.90,Main,,0,0,0,,Vamos cortar as cabeças deles
Dialogue: 0,0:16:12.90,0:16:17.07,Main,,0,0,0,,para mostrar ao mundo\Ndo que o bando do Caribou é capaz!
Dialogue: 0,0:16:17.07,0:16:18.47,Main,,0,0,0,,Sim!
Dialogue: 0,0:16:18.47,0:16:23.04,Main,,0,0,0,,Eles não estão preparados pro combate!\NSerá um ataque totalmente surpresa!
Dialogue: 0,0:16:23.04,0:16:25.84,Main,,0,0,0,,Não cometam erros, homens!
Dialogue: 0,0:16:25.84,0:16:27.21,Main,,0,0,0,,Sim!
Dialogue: 0,0:16:27.21,0:16:29.28,Main,,0,0,0,,Sim! Sim!
Dialogue: 0,0:16:29.28,0:16:33.32,Main,,0,0,0,,Ei, pessoal! Perto da popa,\Ntem um sombra que parece um navio!
Dialogue: 0,0:16:33.32,0:16:34.29,Main,,0,0,0,,O quê?!
Dialogue: 0,0:16:34.29,0:16:34.92,Main,,0,0,0,,Um navio?!
Dialogue: 0,0:16:34.92,0:16:36.49,Main,,0,0,0,,Está vindo na nossa direção!
Dialogue: 0,0:16:36.49,0:16:38.49,Main,,0,0,0,,Atacar!
Dialogue: 0,0:16:43.50,0:16:44.96,Main,,0,0,0,,É um navio pirata!
Dialogue: 0,0:16:44.96,0:16:46.67,Main,,0,0,0,,Estão nos empurrando!
Dialogue: 0,0:16:46.67,0:16:50.04,Main,,0,0,0,,Desviem, ou a bolha vai estourar!
Dialogue: 0,0:16:50.80,0:16:53.71,Main,,0,0,0,,Não! Eles vão atravessar a bolha!
Dialogue: 0,0:16:54.64,0:16:55.81,Main,,0,0,0,,Quem são eles?!
Dialogue: 0,0:16:55.81,0:16:58.04,Main,,0,0,0,,Muito bem, Vaca Marinha!
Dialogue: 0,0:16:58.04,0:16:59.11,Main,,0,0,0,,Sim!
Dialogue: 0,0:16:59.11,0:17:00.61,Main,,0,0,0,,Eles querem subir a bordo?
Dialogue: 0,0:17:00.61,0:17:01.71,Main,,0,0,0,,Vaca Marinha?
Dialogue: 0,0:17:02.75,0:17:04.08,Main,,0,0,0,,Peraí! Aquilo é...
Dialogue: 0,0:17:08.45,0:17:11.86,Main,,0,0,0,,Ótimos! Vamos lá?!
Dialogue: 0,0:17:11.86,0:17:13.06,Main,,0,0,0,,Sim!
Dialogue: 0,0:17:13.06,0:17:16.93,Main,,0,0,0,,Ei, Mohmoo! Você é o Mohmoo\Ndos Piratas de Arlong, não é?
Dialogue: 0,0:17:17.96,0:17:19.73,Main,,0,0,0,,Lembra de mim?
Dialogue: 0,0:17:21.90,0:17:24.77,Main,,0,0,0,,Ei, Luffy, ele não parece familiar?
Dialogue: 0,0:17:25.17,0:17:26.51,Main,,0,0,0,,Você acha?
Dialogue: 0,0:17:27.37,0:17:29.64,Flashbacks,,0,0,0,,Vai para o inferno!
Dialogue: 0,0:17:29.64,0:17:31.91,Flashbacks,,0,0,0,,Gomu, gomu no... Pistol!
Dialogue: 0,0:17:35.28,0:17:37.55,Main,,0,0,0,,Vamos invadir o convés deles!
Dialogue: 0,0:17:37.55,0:17:38.32,Main,,0,0,0,,Sim!
Dialogue: 0,0:17:40.35,0:17:42.15,Main,,0,0,0,,Ah, tem alguém vindo!
Dialogue: 0,0:17:42.15,0:17:45.66,Main,,0,0,0,,Homens, estão prontos?!
Dialogue: 0,0:17:45.66,0:17:46.76,Main,,0,0,0,,Sim!
Dialogue: 0,0:17:47.56,0:17:55.00,Main,,0,0,0,,Eles ainda não estão prontos pra lutar!
Dialogue: 0,0:17:55.00,0:17:58.54,Main,,0,0,0,,Matem todos!
Dialogue: 0,0:18:00.11,0:18:00.94,Main,,0,0,0,,Vamos!
Dialogue: 0,0:18:00.94,0:18:02.31,Main,,0,0,0,,Sim!
Dialogue: 0,0:18:02.31,0:18:05.71,Main,,0,0,0,,Homens, sigam-me!
Dialogue: 0,0:18:08.28,0:18:11.25,Main,,0,0,0,,O quê?!
Dialogue: 0,0:18:11.25,0:18:12.88,Main,,0,0,0,,O que houve, Vaca Marinha?
Dialogue: 0,0:18:12.88,0:18:14.35,Main,,0,0,0,,Por que, Vaca Marinha?!
Dialogue: 0,0:18:14.35,0:18:17.42,Main,,0,0,0,,Ah, não! Deixamos o Capitão Caribou no navio!
Dialogue: 0,0:18:17.42,0:18:19.42,Main,,0,0,0,,Irmão?!
Dialogue: 0,0:18:19.82,0:18:23.76,Main,,0,0,0,,Agora, para dar as boas-vindas,
Dialogue: 0,0:18:24.43,0:18:28.17,Main,,0,0,0,,comecem disparando as metralhadoras!
Dialogue: 0,0:18:28.17,0:18:34.57,Main,,0,0,0,,Matem todos os Chapéus de Palha e...
Dialogue: 0,0:18:42.58,0:18:47.49,Main,,0,0,0,,Não! Não me jogue na água!
Dialogue: 0,0:18:47.49,0:18:48.79,Main,,0,0,0,,Você não pode, moço!
Dialogue: 0,0:18:48.79,0:18:50.16,Main,,0,0,0,,Você não pode fazer isso!
Dialogue: 0,0:18:50.16,0:18:53.93,Main,,0,0,0,,Tem que dar valor à vida!
Dialogue: 0,0:18:53.93,0:18:58.76,Main,,0,0,0,,Deus... Deus está vendo tudo, sabia?!
Dialogue: 0,0:18:59.20,0:19:01.63,Main,,0,0,0,,Não venha com esse papinho agora!
Dialogue: 0,0:19:01.63,0:19:05.14,Main,,0,0,0,,Você queria metralhar todo mundo, maldito!
Dialogue: 0,0:19:05.20,0:19:09.71,Main,,0,0,0,,Quem é você? Deve ser\No capitão daquele navio.
Dialogue: 0,0:19:09.71,0:19:11.88,Thoughts,,0,0,0,,Ah, Roronoa Zoro!
Dialogue: 0,0:19:11.94,0:19:16.88,Main,,0,0,0,,Não, eu não sou capitão! Eu só...
Dialogue: 0,0:19:16.88,0:19:20.99,Main,,0,0,0,,É que eles me escravizaram!
Dialogue: 0,0:19:22.55,0:19:25.02,Main,,0,0,0,,Ah, estou cansado de ficar naquele navio!
Dialogue: 0,0:19:25.02,0:19:26.69,Main,,0,0,0,,Ah, sim! Ótimo!
Dialogue: 0,0:19:26.69,0:19:30.16,Main,,0,0,0,,Posso ficar neste barco aqui com vocês?
Dialogue: 0,0:19:30.16,0:19:31.30,Main,,0,0,0,,Por favor?
Dialogue: 0,0:19:31.30,0:19:34.83,Main,,0,0,0,,Olha, até que me dá um pouco de pena...
Dialogue: 0,0:19:34.83,0:19:37.54,Main,,0,0,0,,Nem pensar! Ele está inventando isso tudo!
Dialogue: 0,0:19:37.54,0:19:39.97,Main,,0,0,0,,O quê?! Ele inventou tudo?!
Dialogue: 0,0:19:39.97,0:19:44.08,Main,,0,0,0,,Ei, onde você achou a Vaca Marinha\Nque estava puxando seu navio?
Dialogue: 0,0:19:44.08,0:19:45.81,Main,,0,0,0,,Oh...
Dialogue: 0,0:19:47.45,0:19:51.15,Main,,0,0,0,,Aí está a lindinha do bando!
Dialogue: 0,0:19:51.72,0:19:54.32,Main,,0,0,0,,Você é a Gata Ladra, não é?
Dialogue: 0,0:19:54.32,0:19:59.39,Main,,0,0,0,,Pare de olhar pra\Nnossa navegadora assim!
Dialogue: 0,0:19:59.82,0:20:03.23,Main,,0,0,0,,Nami! Você está a salvo...
Dialogue: 0,0:20:03.23,0:20:04.96,Main,,0,0,0,,Agora!
Dialogue: 0,0:20:04.96,0:20:07.47,Main,,0,0,0,,Isso já tá enchendo o saco!
Dialogue: 0,0:20:07.47,0:20:12.27,Main,,0,0,0,,Eu peguei esse monstro marinho por aí...
Dialogue: 0,0:20:13.00,0:20:18.14,Main,,0,0,0,,Gente experiente usa esses\Nanimais para puxar navios...
Dialogue: 0,0:20:18.14,0:20:19.48,Main,,0,0,0,,O quê?!
Dialogue: 0,0:20:19.48,0:20:21.41,Main,,0,0,0,,É mesmo?
Dialogue: 0,0:20:21.75,0:20:23.88,Main,,0,0,0,,Pare! Pare, Vaca Marinha!
Dialogue: 0,0:20:23.88,0:20:25.28,Main,,0,0,0,,O que aconteceu?
Dialogue: 0,0:20:25.28,0:20:28.95,Main,,0,0,0,,Irmão! Eu vou te salvar!
Dialogue: 0,0:20:29.62,0:20:32.52,Main,,0,0,0,,Eu quero achar um monstro marinho!
Dialogue: 0,0:20:32.52,0:20:35.86,Main,,0,0,0,,Ei, Luffy! O que você está tramando?
Dialogue: 0,0:20:36.46,0:20:40.57,Main,,0,0,0,,Vamos começar a reabilitação dele\Ncom algumas imagens menos estimulantes.
Dialogue: 0,0:20:40.57,0:20:42.10,Main,,0,0,0,,Ei, Nami...
Dialogue: 0,0:20:42.10,0:20:45.27,Main,,0,0,0,,Não estamos indo exatamente na\Ndireção que o Log Pose aponta.
Dialogue: 0,0:20:45.54,0:20:46.90,Main,,0,0,0,,Ah, tudo bem.
Dialogue: 0,0:20:47.44,0:20:51.11,Main,,0,0,0,,É melhor desviar um pouco a sudoeste\Nde onde ele está apontando.
Dialogue: 0,0:20:51.11,0:20:55.85,Main,,0,0,0,,É mais rápido ir direto.\NPor que estamos fazendo isso?
Dialogue: 0,0:20:55.85,0:21:00.28,Main,,0,0,0,,Se formos direto, seremos pegos\Npela corrente marítima
Dialogue: 0,0:21:00.28,0:21:03.75,Main,,0,0,0,,e acabaremos presos em uma montanha,\Nou um vulcão submarino.
Dialogue: 0,0:21:03.75,0:21:07.43,Main,,0,0,0,,Um vulcão?! Que medo do fundo do mar!
Dialogue: 0,0:21:07.43,0:21:12.46,Main,,0,0,0,,Mas achei que as correntes marítimas\Nna Grand Line fossem voláteis...
Dialogue: 0,0:21:12.46,0:21:14.77,Main,,0,0,0,,Existe alguma corrente estável?
Dialogue: 0,0:21:15.07,0:21:16.73,Main,,0,0,0,,Sim, só uma.
Dialogue: 0,0:21:16.73,0:21:19.77,Main,,0,0,0,,Pessoal! Agora vai ficar mais frio,
Dialogue: 0,0:21:19.77,0:21:21.77,Main,,0,0,0,,então vistam um casaco, ou coisa assim.
Dialogue: 0,0:21:21.77,0:21:25.94,Main,,0,0,0,,Está esfriando mesmo, já dá pra sentir na pele.
Dialogue: 0,0:21:25.94,0:21:28.08,Main,,0,0,0,,Ah, mas eu não..
Dialogue: 0,0:21:28.08,0:21:30.58,Main,,0,0,0,,Você é um esqueleto, não tem pele.
Dialogue: 0,0:21:32.12,0:21:35.35,Main,,0,0,0,,Estamos indo para um lugar frio?\NMas não fica no fundo do mar?
Dialogue: 0,0:21:35.35,0:21:38.89,Main,,0,0,0,,Não sabia que a água\Nno fundo do mar é gelada?
Dialogue: 0,0:21:38.89,0:21:42.13,Main,,0,0,0,,Como numa banheira, a água quente\Nsobe e a água fria desce.
Dialogue: 0,0:21:42.39,0:21:44.03,Main,,0,0,0,,Entendi!
Dialogue: 0,0:21:44.03,0:21:46.23,Main,,0,0,0,,Se o mar é como uma banheira,
Dialogue: 0,0:21:46.23,0:21:48.30,Main,,0,0,0,,quanto mais descermos,\Nmais vai ficar frio.
Dialogue: 0,0:21:48.30,0:21:51.20,Main,,0,0,0,,A temperatura não vai ser\Na única coisa a mudar.
Dialogue: 0,0:21:52.14,0:21:54.31,Main,,0,0,0,,Ainda está deprimido?!
Dialogue: 0,0:21:54.31,0:21:55.71,Main,,0,0,0,,Na camada mais profunda do oceano,
Dialogue: 0,0:21:56.21,0:21:59.74,Main,,0,0,0,,há correntes gigantes chamadas\Nde correntes profundas,
Dialogue: 0,0:21:59.74,0:22:02.85,Main,,0,0,0,,que são um tanto raras.
Dialogue: 0,0:22:02.85,0:22:08.02,Main,,0,0,0,,Essas correntes fluem de forma totalmente\Nindependente das correntes da superfície.
Dialogue: 0,0:22:08.02,0:22:12.79,Main,,0,0,0,,Correntes embaixo de correntes?!\NComo você é sabido!
Dialogue: 0,0:22:14.26,0:22:15.86,Main,,0,0,0,,É que eu sou bem velho!
Dialogue: 0,0:22:16.16,0:22:19.63,Main,,0,0,0,,Todas as correntes do mundo são conectadas.
Dialogue: 0,0:22:19.63,0:22:22.93,Main,,0,0,0,,Algumas fluem para o leste.\NOutras, para o oeste.
Dialogue: 0,0:22:22.93,0:22:25.87,Main,,0,0,0,,Mas também podem fluir para cima ou para baixo.
Dialogue: 0,0:22:25.87,0:22:28.77,Main,,0,0,0,,É como um dragão gigante.
Dialogue: 0,0:22:28.77,0:22:33.24,Main,,0,0,0,,Correntes profundas fluem bem devagar...
Dialogue: 0,0:22:33.24,0:22:38.78,Main,,0,0,0,,Quando começam a fluir para o fundo do mar, elas\Nlevam até dois mil anos
Dialogue: 0,0:22:38.78,0:22:41.99,Main,,0,0,0,,para voltar a fluir na\Ndireção da superfície.
Dialogue: 0,0:22:41.99,0:22:43.55,Main,,0,0,0,,Dois mil anos?!
Dialogue: 0,0:22:43.55,0:22:44.99,Main,,0,0,0,,Sim...
Dialogue: 0,0:22:44.99,0:22:49.29,Main,,0,0,0,,Por isso, há uma série de mitos
Dialogue: 0,0:22:49.29,0:22:52.73,Main,,0,0,0,,sobre as tenebrosas e nunca\Nantes vistas correntes profundas.
Dialogue: 0,0:22:52.73,0:22:57.90,Main,,0,0,0,,Monstros! Maldições! Espíritos dos mortos!
Dialogue: 0,0:22:57.90,0:23:01.54,Main,,0,0,0,,O quê?! Há fantasmas no fundo do mar?!
Dialogue: 0,0:23:01.54,0:23:03.34,Main,,0,0,0,,Sério? Que medo!
Dialogue: 0,0:23:03.34,0:23:04.64,Main,,0,0,0,,Que maneiro!
Dialogue: 0,0:23:04.64,0:23:08.51,Main,,0,0,0,,Fantasmas? Eu não chegaria a tanto...
Dialogue: 0,0:23:08.51,0:23:13.85,Main,,0,0,0,,Mas nós vamos pegar\Numa corrente descendente.
Dialogue: 0,0:23:13.85,0:23:17.99,Main,,0,0,0,,É assim que vamos chegar no fundo do mar.
Dialogue: 0,0:23:18.42,0:23:21.66,Main,,0,0,0,,Correntes são um barato\Nbem misterioso...
Dialogue: 0,0:23:21.66,0:23:24.30,Main,,0,0,0,,Vocês nem sabem do que\Nestou falando, não é?!
Dialogue: 0,0:23:24.30,0:23:25.86,Main,,0,0,0,,Você quer cantar, Nami?
Dialogue: 0,0:23:25.86,0:23:27.80,Main,,0,0,0,,Nami, estou vendo!
Dialogue: 0,0:23:27.80,0:23:28.70,Main,,0,0,0,,Sério?
Dialogue: 0,0:23:28.70,0:23:30.57,Main,,0,0,0,,A corrente misteriosa?
Dialogue: 0,0:23:32.34,0:23:33.40,Main,,0,0,0,,O que é aquilo?
Dialogue: 0,0:23:33.40,0:23:35.61,Main,,0,0,0,,Plume, a corrente descendente!
Dialogue: 0,0:23:36.94,0:23:39.81,Main,,0,0,0,,Que maneiro!
Dialogue: 0,0:23:39.81,0:23:42.95,Main,,0,0,0,,Parece uma enorme...
Dialogue: 0,0:23:45.15,0:23:48.92,Main,,0,0,0,,Cachoeira submarina!
Dialogue: 0,0:23:51.29,0:23:52.79,Main,,0,0,0,,Que legal!
Dialogue: 0,0:23:53.59,0:23:58.90,Main,,0,0,0,,O mar está despencando\Nnuma velocidade fantástica!
Dialogue: 0,0:23:59.33,0:24:01.37,Main,,0,0,0,,A natureza é fantástica!
Dialogue: 0,0:24:01.37,0:24:06.37,Main,,0,0,0,,Que corrente espetacular! Até que\Nprofundidade será que ela vai?
Dialogue: 0,0:24:06.70,0:24:11.08,Main,,0,0,0,,É bem maior do que falaram.
Dialogue: 0,0:24:11.44,0:24:15.31,Main,,0,0,0,,Não consigo ver o fundo!\NEstá completamente escuro!
Dialogue: 0,0:24:15.31,0:24:17.11,Main,,0,0,0,,Vamos morrer!
Dialogue: 0,0:24:17.11,0:24:21.95,Main,,0,0,0,,Nessa velocidade, vamos bater com\Ntudo no fundo do mar e morrer!
Dialogue: 0,0:24:21.95,0:24:25.39,Main,,0,0,0,,É mesmo seguro navegar nessa corrente?
Dialogue: 0,0:24:25.39,0:24:27.46,Main,,0,0,0,,Não se preocupem com o navio.
Dialogue: 0,0:24:27.46,0:24:32.33,Main,,0,0,0,,O Sunny é o mais poderoso navio possível,\Nconstruído de madeira de Adão.
Dialogue: 0,0:24:32.33,0:24:34.13,Main,,0,0,0,,Beleza!
Dialogue: 0,0:24:34.83,0:24:36.37,Main,,0,0,0,,Avançar!
Dialogue: 0,0:24:37.97,0:24:39.30,Main,,0,0,0,,Não pode ser!
Dialogue: 0,0:24:39.30,0:24:44.04,Main,,0,0,0,,Eu não sabia que isso morava aqui...
Dialogue: 0,0:24:44.51,0:24:48.15,Main,,0,0,0,,O demônio que reina nas águas...
Dialogue: 0,0:24:48.15,0:24:50.88,Main,,0,0,0,,O inimigo da raça humana!
Dialogue: 0,0:24:50.88,0:24:54.75,Main,,0,0,0,,Chapéus de Palha! Deem meia-volta!
Dialogue: 0,0:24:54.75,0:24:56.55,Main,,0,0,0,,É perigoso!
Dialogue: 0,0:24:56.55,0:24:58.39,Main,,0,0,0,,Eu já tinha me esquecido de você!
Dialogue: 0,0:24:58.39,0:25:00.09,Main,,0,0,0,,Tem um monstro lá embaixo!
Dialogue: 0,0:25:00.09,0:25:01.12,Main,,0,0,0,,O quê?!
Dialogue: 0,0:25:05.00,0:25:07.93,Main,,0,0,0,,É o Kraken!
Dialogue: 0,0:25:09.20,0:25:11.47,Main,,0,0,0,,Que enorme monstro-polvo!
Dialogue: 0,0:25:12.20,0:25:14.87,Main,,0,0,0,,Parece que ele já\Ndestruiu uma frota de navios!
Dialogue: 0,0:25:15.44,0:25:18.38,Main,,0,0,0,,Navios que partiram para\No Novo Mundo foram atacados!
Dialogue: 0,0:25:18.38,0:25:22.88,Main,,0,0,0,,Por favor, voltem! Eu não quero morrer!
Dialogue: 0,0:25:22.88,0:25:26.55,Main,,0,0,0,,Se vocês esperarem mais\Nalguns dias, talvez...
Dialogue: 0,0:25:26.55,0:25:28.45,Main,,0,0,0,,Cale a boca!
Dialogue: 0,0:25:29.29,0:25:31.79,Main,,0,0,0,,Tive uma ideia!
Dialogue: 0,0:25:32.72,0:25:34.56,Main,,0,0,0,,Vamos domesticá-lo!
Dialogue: 0,0:25:37.16,0:25:39.83,Main,,0,0,0,,O que você disse, Luffy?!
Dialogue: 0,0:25:39.83,0:25:42.90,Main,,0,0,0,,Vamos domesticar o polvo\Ne fazê-lo puxar nosso navio!
Dialogue: 0,0:25:42.90,0:25:45.10,Main,,0,0,0,,Impossível!
Dialogue: 0,0:25:45.10,0:25:46.54,Main,,0,0,0,,Olha só pra ele!
Dialogue: 0,0:25:46.54,0:25:50.07,Main,,0,0,0,,E nem precisa fazer esforço pra ver,\Nporque olha o tamanho do bicho!
Dialogue: 0,0:25:50.07,0:25:52.48,Main,,0,0,0,,Ah, como é grande!
Dialogue: 0,0:25:52.64,0:25:55.28,Main,,0,0,0,,Ele deve vagar por esses mares\Nhá centenas de anos!
Dialogue: 0,0:25:55.28,0:25:58.52,Main,,0,0,0,,O Kraken é assunto de lendas pelo mundo todo,
Dialogue: 0,0:25:58.52,0:26:01.22,Main,,0,0,0,,uma criatura mitológica!
Comment: 0,0:00:00.03,0:00:00.03,Main,,0,0,0,,

