{
  "name": "onepace-ptbr-subs-addon",
  "version": "1.0.0",
  "description": "Addon do Stremio que fornece legendas em PT-BR para o One Pace",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "convert": "python3 scripts/convert-ass-to-srt.py ../one-pace-public-subtitles ./subs",
    "download": "python3 scripts/download-all-subs.py",
    "download:dry": "python3 scripts/download-all-subs.py --dry-run"
  },
  "dependencies": {
    "stremio-addon-sdk": "^1.6.10"
  },
  "keywords": ["stremio", "addon", "subtitles", "one-pace", "portuguese", "pt-br"],
  "license": "MIT"
}
